      <button class="modal-adj-btn" onclick="editSetCount(-1)">−</button>
      <div class="modal-val-display" id="ex-edit-setcount" style="min-width:60px;">3</div>
      <button class="modal-adj-btn" onclick="editSetCount(1)">＋</button>
    </div>
