  <!-- ════════════════ EXERCISE EDIT MODAL ════════════════ -->
  <div id="ex-edit-overlay" onclick="closeExEdit()"></div>
  <div id="ex-edit-modal">
    <div class="modal-handle"></div>
    <div class="modal-title" id="ex-edit-name">Übung</div>
    <p class="modal-set-lbl" style="margin-bottom:6px;">Sätze (heute)</p>
