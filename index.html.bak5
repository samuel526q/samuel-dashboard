    <!-- Reps -->
    <div class="modal-row">
      <span class="modal-label">REP</span>
      <button class="modal-adj-btn" onclick="adjustReps(-1)">−</button>
      <div class="modal-val-display" id="modal-reps">—</div>
      <button class="modal-adj-btn" onclick="adjustReps(1)">＋</button>
    </div>
    <div class="quick-chips" id="quick-chips"></div>
