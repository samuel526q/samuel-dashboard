// ══════════════════════════════════════════════════════
// SOUND ENGINE
// ══════════════════════════════════════════════════════
const AudioCtx = window.AudioContext || window.webkitAudioContext;
let audioCtx = null;
let soundEnabled = true;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new AudioCtx();
  return audioCtx;
}

function playSound(type) {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const notes = {
      welcome:   [[523,0,0.15],[659,0.15,0.15],[784,0.3,0.2]],
      check:     [[880,0,0.08]],
      milestone: [[523,0,0.1],[659,0.1,0.1],[784,0.2,0.1],[1047,0.3,0.2]],
      confetti:  [[784,0,0.08],[988,0.1,0.08],[1175,0.2,0.15]]
    };
    (notes[type]||notes.check).forEach(([freq,delay,dur])=>{
      const osc=ctx.createOscillator(), gain=ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value=freq; osc.type='sine';
      gain.gain.setValueAtTime(0.12,ctx.currentTime+delay);
      gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+delay+dur);
      osc.start(ctx.currentTime+delay); osc.stop(ctx.currentTime+delay+dur+0.05);
    });
  } catch(e){}
}

function toggleSound() {
  soundEnabled = !soundEnabled;
  document.getElementById('sound-toggle').textContent = soundEnabled ? 'An' : 'Aus';
  localStorage.setItem('soundEnabled', soundEnabled);
}

function showConfetti() {
  const el = document.createElement('div');
  el.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
  document.body.appendChild(el);
  const colors=['#6366f1','#10b981','#f59e0b','#ef4444','#a855f7'];
  for(let i=0;i<40;i++){
    const p=document.createElement('div');
    const c=colors[Math.floor(Math.random()*colors.length)];
    p.style.cssText=`position:absolute;width:8px;height:8px;background:${c};border-radius:2px;left:${Math.random()*100}%;top:-10px;animation:confettiFall ${1+Math.random()*2}s linear forwards;opacity:${0.7+Math.random()*0.3};`;
    el.appendChild(p);
  }
  const style=document.createElement('style');
  style.textContent='@keyframes confettiFall{to{transform:translateY(100vh) rotate(720deg);opacity:0;}}';
  document.head.appendChild(style);
  setTimeout(()=>el.remove(),3000);
}

function checkMorningComplete() {
  const items = ROUTINE.filter(x=>x.type==='check');
  const done = items.filter((_,i)=>S.routine[i]).length;
  if (done===items.length && done>0) { playSound('confetti'); showConfetti(); }
}

// ══════════════════════════════════════════════════════
// SUPABASE
// ══════════════════════════════════════════════════════
const getCfg = () => ({url: localStorage.getItem('sb_url')||'', key: localStorage.getItem('sb_key')||''});

function setSyncError(hasError) {
  const dot = document.getElementById('sync-err-dot');
  if (dot) dot.classList.toggle('visible', hasError);
}

async function _supabaseUpsert(c, key, value) {
  await fetch(`${c.url}/rest/v1/app_state`, {
    method:'POST',
    headers:{'apikey':c.key,'Authorization':`Bearer ${c.key}`,'Content-Type':'application/json','Prefer':'resolution=merge-duplicates'},
    body: JSON.stringify({key, value, updated_at: new Date().toISOString()})
  });
}

async function flushPendingSync() {
  const c = getCfg();
  if (!c.url || !c.key) return;
  const pending = JSON.parse(localStorage.getItem('_pending_sync') || '[]');
  if (!pending.length) return;
  const remaining = [];
  for (const item of pending) {
    try { await _supabaseUpsert(c, item.key, item.value); }
    catch(e) { remaining.push(item); }
  }
  localStorage.setItem('_pending_sync', JSON.stringify(remaining));
  setSyncError(remaining.length > 0);
}

async function upsert(key, value) {
  localStorage.setItem(key, JSON.stringify(value));
  const c = getCfg();
  if (!c.url || !c.key) return;
  try {
    await _supabaseUpsert(c, key, value);
    // clear this key from pending queue if it was there
    const pending = JSON.parse(localStorage.getItem('_pending_sync') || '[]');
    const filtered = pending.filter(p => p.key !== key);
    if (filtered.length !== pending.length) {
      localStorage.setItem('_pending_sync', JSON.stringify(filtered));
      setSyncError(filtered.length > 0);
    }
  } catch(e) {
    const pending = JSON.parse(localStorage.getItem('_pending_sync') || '[]');
    const idx = pending.findIndex(p => p.key === key);
    if (idx >= 0) pending[idx] = {key, value};
    else pending.push({key, value});
    localStorage.setItem('_pending_sync', JSON.stringify(pending.slice(-50)));
    setSyncError(true);
  }
}

async function dbRead(key) {
  const local = localStorage.getItem(key);
  const c = getCfg();
  if (!c.url || !c.key) return local ? JSON.parse(local) : null;
  try {
    const r = await fetch(`${c.url}/rest/v1/app_state?key=eq.${encodeURIComponent(key)}&select=value`, {
      headers:{'apikey':c.key,'Authorization':`Bearer ${c.key}`}
    });
    const d = await r.json();
    if (d[0]?.value !== undefined) { localStorage.setItem(key, JSON.stringify(d[0].value)); return d[0].value; }
  } catch(e){}
  return local ? JSON.parse(local) : null;
}

// ══════════════════════════════════════════════════════
// GESUNDHEIT TAB
// ══════════════════════════════════════════════════════

function computeReadiness(d) {
  if (!d) return { score: null, status: 'NO_DATA', title: 'Keine Daten heute', hint: 'Shortcut ausführen, um Werte zu syncen.' };
  const parts = [];
  if (d.hrv_ms)        parts.push({ w: 0.40, v: Math.max(0, Math.min(1, (d.hrv_ms - 30) / 50)) });
  if (d.rhr_bpm)       parts.push({ w: 0.25, v: Math.max(0, Math.min(1, (80 - d.rhr_bpm) / 30)) });
  if (d.sleep_minutes) parts.push({ w: 0.35, v: Math.max(0, Math.min(1, (d.sleep_minutes/60 - 5) / 3.5)) });
  if (parts.length === 0) return { score: null, status: 'NO_DATA', title: 'Keine Daten heute', hint: 'Werte werden gleich syncen.' };
  const totW  = parts.reduce((s,p) => s + p.w, 0);
  const score = Math.round(parts.reduce((s,p) => s + p.v * p.w, 0) / totW * 100);
  let status, title, hint;
  if      (score >= 80) { status = 'OPTIMAL';  title = 'Optimal erholt';  hint = 'Geh ans Limit — alle Systeme grün.'; }
  else if (score >= 65) { status = 'SOLID';    title = 'Gut bereit';       hint = 'Solides Training möglich, kein Limit.'; }
  else if (score >= 45) { status = 'OK';       title = 'Akzeptabel';       hint = 'Eher moderates Volumen, Recovery priorisieren.'; }
  else                  { status = 'STRAINED'; title = 'Stark belastet';   hint = 'Heute Erholung > Leistung. Schlaf & Spaziergang.'; }
  return { score, status, title, hint };
}

function trendArrow(vals, betterWhen = 'up') {
  const v = vals.filter(x => x !== null && x !== undefined);
  if (v.length < 2) return { arrow: '→', cls: 'flat', delta: 0 };
  const recent  = v.slice(-3).reduce((s,x) => s+x, 0) / Math.min(3, v.length);
  const earlier = v.slice(0,3).reduce((s,x) => s+x, 0) / Math.min(3, v.slice(0,3).length);
  const delta   = recent - earlier;
  const rising  = delta >  Math.abs(earlier) * 0.02;
  const falling = delta < -Math.abs(earlier) * 0.02;
  if (!rising && !falling) return { arrow: '→', cls: 'flat', delta };
  if (rising)  return { arrow: '↗', cls: betterWhen === 'up'   ? 'up'   : 'down', delta };
  if (falling) return { arrow: '↘', cls: betterWhen === 'down' ? 'up'   : 'down', delta };
}

function sparkSVG(vals, color, fill = false) {
  const valid = vals.filter(v => v !== null && v !== undefined);
  if (valid.length < 2) return '<svg class="hm-spark"></svg>';
  const lo = Math.min(...valid), hi = Math.max(...valid), range = hi - lo || 1;
  const w = 100, h = 22, pad = 2;
  let prevX = pad;
  const pts = vals.map((v, i) => {
    const x = pad + (i / (vals.length - 1)) * (w - pad*2);
    if (v === null || v === undefined) return null;
    const y = h - pad - ((v - lo) / range) * (h - pad*2);
    prevX = x; return [x, y];
  });
  const linePts = pts.filter(Boolean).map(([x,y]) => `${x.toFixed(1)},${y.toFixed(1)}`).join(' ');
  const fillPath = fill ? `<polygon points="${pad},${h-pad} ${linePts} ${prevX.toFixed(1)},${h-pad}" fill="${color}" opacity="0.10"/>` : '';
  return `<svg viewBox="0 0 ${w} ${h}" class="hm-spark" preserveAspectRatio="none">
    ${fillPath}
    <polyline points="${linePts}" fill="none" stroke="${color}" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`;
}

function trendSparkSVG(vals, color) {
  const valid = vals.filter(v => v !== null && v !== undefined);
  if (valid.length < 2) return '<svg class="trend-spark"></svg>';
  const lo = Math.min(...valid), hi = Math.max(...valid), range = hi - lo || 1;
  const w = 100, h = 32, pad = 3;
  const pts = vals.map((v, i) => {
    if (v === null || v === undefined) return null;
    const x = pad + (i / (vals.length - 1)) * (w - pad*2);
    const y = h - pad - ((v - lo) / range) * (h - pad*2);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).filter(Boolean).join(' ');
  const lastV = valid[valid.length - 1];
  const lastIdx = vals.lastIndexOf(lastV);
  const lastX = pad + (lastIdx / (vals.length - 1)) * (w - pad*2);
  const lastY = h - pad - ((lastV - lo) / range) * (h - pad*2);
  return `<svg viewBox="0 0 ${w} ${h}" class="trend-spark" preserveAspectRatio="none">
    <polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.9"/>
    <circle cx="${lastX.toFixed(1)}" cy="${lastY.toFixed(1)}" r="2" fill="${color}"/>
  </svg>`;
}

function heroMetricCard(opts) {
  const { lbl, val, unit, status, spark, trend, sub } = opts;
  const nodata   = val === null || val === undefined;
  const trendBit = trend ? `<span class="delta">${trend.arrow}</span><span>${sub || ''}</span>` : '';
  return `
    <div class="hm-card hm-${status || 'muted'}${nodata ? ' no-data' : ''}">
      <div class="hm-lbl"><span class="dot"></span>${lbl}</div>
      <div class="hm-val">${nodata ? '—' : val}${!nodata && unit ? `<span class="u">${unit}</span>` : ''}</div>
      <div class="hm-trend">${nodata ? '<span>kein Wert</span>' : trendBit}</div>
      ${spark || ''}
    </div>`;
}

function renderReadiness(d) {
  const r    = computeReadiness(d);
  const hero = document.getElementById('readiness-hero');
  const ring = document.getElementById('readiness-ring');
  const num  = document.getElementById('readiness-num');
  const pill = document.getElementById('readiness-pill');
  const ttl  = document.getElementById('readiness-title');
  const hint = document.getElementById('readiness-hint');
  if (!hero) return;
  hero.className = 'rd-hero rd-status-' + r.status;
  if (r.score === null) {
    num.textContent = '—';
    ring.style.strokeDashoffset = 364.4;
  } else {
    num.textContent = r.score;
    const circ = 2 * Math.PI * 58;
    ring.style.strokeDashoffset = circ - (r.score / 100) * circ;
  }
  pill.textContent = r.status === 'NO_DATA' ? 'Keine Daten' : r.status;
  ttl.textContent  = r.title;
  hint.textContent = r.hint;
}

function renderHeroMetrics(d, history) {
  const wrap = document.getElementById('hero-metrics-wrap');
  if (!wrap) return;
  if (!d) {
    wrap.innerHTML = `<div class="gh-loading" style="grid-column: span 3;">Noch keine Gesundheitsdaten — Shortcut einrichten</div>`;
    return;
  }
  const hrvHist   = history.map(r => r.hrv_ms        || null);
  const rhrHist   = history.map(r => r.rhr_bpm       || null);
  const sleepHist = history.map(r => r.sleep_minutes  ? +(r.sleep_minutes/60).toFixed(2) : null);

  const hrvStatus   = !d.hrv_ms       ? 'muted' : d.hrv_ms   >= 60  ? 'good' : d.hrv_ms   >= 40 ? 'okay' : 'bad';
  const rhrStatus   = !d.rhr_bpm      ? 'muted' : d.rhr_bpm  <= 60  ? 'good' : d.rhr_bpm  <= 75 ? 'okay' : 'bad';
  const sleepHrs    = d.sleep_minutes  ? d.sleep_minutes / 60 : null;
  const sleepStatus = !sleepHrs        ? 'muted' : sleepHrs   >= 7.5 ? 'good' : sleepHrs   >= 6  ? 'okay' : 'bad';

  const hrvT   = trendArrow(hrvHist,   'up');
  const rhrT   = trendArrow(rhrHist,   'down');
  const sleepT = trendArrow(sleepHist, 'up');

  const col = s => s === 'good' ? '#34d399' : s === 'okay' ? '#fbbf24' : s === 'bad' ? '#f87171' : '#94a3b8';
  const sleepHHMM = sleepHrs
    ? `${Math.floor(sleepHrs)}:${String(Math.round((sleepHrs % 1) * 60)).padStart(2,'0')}`
    : null;

  wrap.innerHTML = `
    ${heroMetricCard({ lbl:'HRV',      val: d.hrv_ms  ? Math.round(d.hrv_ms)  : null, unit:' ms',  status:hrvStatus,
      sub:`7T ${hrvT.delta > 0?'+':''}${hrvT.delta.toFixed(0)} ms`,   trend:hrvT,   spark:sparkSVG(hrvHist,   col(hrvStatus),   true) })}
    ${heroMetricCard({ lbl:'Ruhepuls', val: d.rhr_bpm ? Math.round(d.rhr_bpm) : null, unit:' bpm', status:rhrStatus,
      sub:`7T ${rhrT.delta > 0?'+':''}${rhrT.delta.toFixed(0)} bpm`,  trend:rhrT,   spark:sparkSVG(rhrHist,   col(rhrStatus),   true) })}
    ${heroMetricCard({ lbl:'Schlaf',   val: sleepHHMM,                                unit:' h',   status:sleepStatus,
      sub:`7T ${sleepT.delta>0?'+':''}${sleepT.delta.toFixed(1)} h`,  trend:sleepT, spark:sparkSVG(sleepHist, col(sleepStatus), true) })}
  `;
}

function renderSleep(d) {
  const card     = document.getElementById('sleep-card');
  const bedtimeEl = document.getElementById('sleep-bedtime');
  if (!card) return;
  if (!d || !d.sleep_minutes) {
    card.innerHTML = `<div class="sleep-empty">Schlafdaten noch nicht verfügbar</div>`;
    if (bedtimeEl) bedtimeEl.textContent = '—';
    return;
  }
  const deep    = d.sleep_deep_minutes  || 0;
  const rem     = d.sleep_rem_minutes   || 0;
  const light   = d.sleep_light_minutes || 0;
  const tracked = deep + rem + light;
  const total   = d.sleep_minutes;
  const hrs     = Math.floor(total / 60);
  const mins    = Math.round(total % 60);
  if (bedtimeEl) bedtimeEl.textContent = d.bedtime ? `Bett ${d.bedtime}` : '';
  const head = `
    <div class="sleep-head">
      <div class="sleep-total"><span class="h">${hrs}</span><span class="m">h ${mins}m</span><span class="lbl">gesamt</span></div>
      ${d.sleep_score ? `<div class="sleep-score"><div class="lbl">Score</div><div class="val">${Math.round(d.sleep_score)}</div></div>` : ''}
    </div>`;
  if (!tracked) {
    card.innerHTML = head + `<div class="sleep-empty">Schlafphasen-Aufschlüsselung noch nicht verfügbar</div>`;
    return;
  }
  const deepPct  = (deep  / tracked) * 100;
  const remPct   = (rem   / tracked) * 100;
  const lightPct = (light / tracked) * 100;
  card.innerHTML = head + `
    <div class="sleep-bar">
      <div class="sleep-seg deep"  style="width:${deepPct}%">${deepPct  > 14 ? `<span class="pct">${Math.round(deepPct)}%</span>`  : ''}</div>
      <div class="sleep-seg rem"   style="width:${remPct}%">${remPct   > 14 ? `<span class="pct">${Math.round(remPct)}%</span>`   : ''}</div>
      <div class="sleep-seg light" style="width:${lightPct}%">${lightPct > 14 ? `<span class="pct">${Math.round(lightPct)}%</span>` : ''}</div>
    </div>
    <div class="sleep-legend">
      <div class="sleep-leg deep"> <div class="lbl">Tief</div>  <div class="val">${Math.round(deep)}<span class="u"> min</span></div></div>
      <div class="sleep-leg rem">  <div class="lbl">REM</div>   <div class="val">${Math.round(rem)}<span class="u"> min</span></div></div>
      <div class="sleep-leg light"><div class="lbl">Leicht</div><div class="val">${Math.round(light)}<span class="u"> min</span></div></div>
    </div>`;
}

function renderActivity(d) {
  const STEPS_GOAL = 8000;
  const stepsPct   = d && d.steps ? Math.min(100, (d.steps / STEPS_GOAL) * 100) : 0;
  const circ       = 2 * Math.PI * 19;
  const rf = document.getElementById('steps-ring-fill');
  if (rf) rf.style.strokeDashoffset = circ - (stepsPct/100) * circ;
  const sp = document.getElementById('steps-pct');
  if (sp) sp.textContent = d && d.steps ? `${Math.round(stepsPct)}%` : '—';
  const sv = document.getElementById('steps-val');
  if (sv) sv.innerHTML = d && d.steps ? d.steps.toLocaleString('de-DE') : '—';
  const ss = document.getElementById('steps-sub');
  if (ss) ss.textContent = d && d.steps
    ? `${STEPS_GOAL - d.steps > 0 ? '−'+(STEPS_GOAL-d.steps).toLocaleString('de-DE') : '+'+(d.steps-STEPS_GOAL).toLocaleString('de-DE')} zum Ziel` : '—';

  const ev = document.getElementById('energy-val');
  if (ev) ev.innerHTML = d && d.active_energy
    ? `${Math.round(d.active_energy)}<span class="u"> kcal</span>` : `—<span class="u"></span>`;
  const es = document.getElementById('energy-sub');
  if (es) es.textContent = d && d.active_energy
    ? (d.active_energy >= 400 ? 'aktiver Tag' : 'unter Schnitt') : 'kein Wert';

  const mv = document.getElementById('move-val');
  if (mv) mv.innerHTML = d && d.exercise_minutes
    ? `${Math.round(d.exercise_minutes)}<span class="u"> min</span>` : `—<span class="u"></span>`;
  const ms2 = document.getElementById('move-sub');
  if (ms2) ms2.textContent = d && d.exercise_minutes
    ? (d.exercise_minutes >= 30 ? 'Ziel erreicht' : `${30 - Math.round(d.exercise_minutes)} min fehlen`) : 'kein Wert';
}

function renderVitals(d) {
  const spo2 = document.getElementById('spo2-val');
  if (spo2) spo2.innerHTML = d && d.spo2
    ? `${Math.round(d.spo2)}<span class="u"> %</span>` : `—<span class="u"></span>`;
  const resp = document.getElementById('resp-val');
  if (resp) resp.innerHTML = d && d.respiratory_rate
    ? `${d.respiratory_rate.toFixed(1)}<span class="u"> /min</span>` : `—<span class="u"></span>`;
}

function renderTrends(history) {
  const wrap = document.getElementById('trend-wrap');
  if (!wrap) return;
  if (!history || history.length < 2) {
    wrap.innerHTML = `<div class="gh-loading" style="grid-column: span 3;">Noch nicht genug Daten (min. 2 Tage)</div>`;
    return;
  }
  const hrv   = history.map(r => r.hrv_ms       || null);
  const rhr   = history.map(r => r.rhr_bpm      || null);
  const sleep = history.map(r => r.sleep_minutes ? +(r.sleep_minutes/60).toFixed(2) : null);
  const avg   = arr => { const v = arr.filter(x => x !== null); return v.length ? v.reduce((s,x)=>s+x,0)/v.length : null; };
  const hrvT  = trendArrow(hrv,   'up');
  const rhrT  = trendArrow(rhr,   'down');
  const sleepT= trendArrow(sleep, 'up');
  wrap.innerHTML = `
    <div class="trend-card">
      <div class="head"><span class="lbl">HRV</span><span class="arrow ${hrvT.cls}">${hrvT.arrow}</span></div>
      <div class="val">${hrv[hrv.length-1] != null ? Math.round(hrv[hrv.length-1]) : '—'}<span class="u"> ms</span></div>
      <div class="avg">Ø ${avg(hrv) ? Math.round(avg(hrv)) : '—'} · 7T</div>
      ${trendSparkSVG(hrv, '#34d399')}
    </div>
    <div class="trend-card">
      <div class="head"><span class="lbl">Ruhepuls</span><span class="arrow ${rhrT.cls}">${rhrT.arrow}</span></div>
      <div class="val">${rhr[rhr.length-1] != null ? Math.round(rhr[rhr.length-1]) : '—'}<span class="u"> bpm</span></div>
      <div class="avg">Ø ${avg(rhr) ? Math.round(avg(rhr)) : '—'} · 7T</div>
      ${trendSparkSVG(rhr, '#f87171')}
    </div>
    <div class="trend-card">
      <div class="head"><span class="lbl">Schlaf</span><span class="arrow ${sleepT.cls}">${sleepT.arrow}</span></div>
      <div class="val">${sleep[sleep.length-1] != null ? (+sleep[sleep.length-1]).toFixed(1) : '—'}<span class="u"> h</span></div>
      <div class="avg">Ø ${avg(sleep) ? avg(sleep).toFixed(1) : '—'} · 7T</div>
      ${trendSparkSVG(sleep, '#a78bfa')}
    </div>`;
}

let hrChartInstance = null;

async function loadGesundheitTab() {
  const dateEl  = document.getElementById('health-tab-date');
  const stampEl = document.getElementById('health-tab-stamp');
  const c = getCfg();
  if (!c.url || !c.key) {
    const wrap = document.getElementById('hero-metrics-wrap');
    if (wrap) wrap.innerHTML = `<div class="gh-loading" style="grid-column: span 3;">Supabase nicht konfiguriert</div>`;
    return;
  }
  try {
    const today     = new Date().toISOString().split('T')[0];
    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
    const res  = await fetch(
      `${c.url}/rest/v1/health_data?select=*&order=date.desc&limit=7`,
      { headers: { 'apikey': c.key, 'Authorization': `Bearer ${c.key}` } }
    );
    const rows    = await res.json();
    const data    = rows && rows.length > 0 ? rows[0] : null;
    const history = rows ? [...rows].reverse() : [];

    if (data) {
      const label    = data.date === today ? 'Heute' : data.date === yesterday ? 'Gestern' : data.date;
      const todayStr = new Date().toLocaleDateString('de-DE', { weekday: 'long', day: 'numeric', month: 'long' });
      if (dateEl)  dateEl.textContent  = `${label} · ${todayStr}`;
      if (stampEl) stampEl.textContent = new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
    } else {
      if (dateEl)  dateEl.textContent  = 'Keine Daten';
      if (stampEl) stampEl.textContent = '—';
    }

    renderReadiness(data);
    renderHeroMetrics(data, history);
    renderSleep(data);
    renderActivity(data);
    renderVitals(data);
    renderTrends(history);
    await loadHRChart(today, c);
  } catch (e) {
    console.error('Gesundheit Tab error:', e);
  }
}

async function loadHRChart(date, c) {
  const canvas  = document.getElementById('hr-chart');
  const emptyEl = document.getElementById('hr-chart-empty');
  const statsEl = document.getElementById('hr-stats');
  if (!canvas) return;
  if (!c || !c.url || !c.key) {
    canvas.style.display = 'none';
    if (emptyEl) emptyEl.style.display = 'block';
    return;
  }
  try {
    const res    = await fetch(
      `${c.url}/rest/v1/heart_rate_timeline?select=hour,avg_bpm&date=eq.${date}&order=hour.asc`,
      { headers: { 'apikey': c.key, 'Authorization': `Bearer ${c.key}` } }
    );
    const hrData = await res.json();

    if (!hrData || hrData.length === 0) {
      canvas.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'block';
      if (statsEl) statsEl.innerHTML = `
        <div class="hr-stat min"><span class="lbl">Min</span><span class="val">—</span></div>
        <div class="hr-stat avg"><span class="lbl">Ø</span><span class="val">—</span></div>
        <div class="hr-stat max"><span class="lbl">Max</span><span class="val">—</span></div>`;
      if (hrChartInstance) { hrChartInstance.destroy(); hrChartInstance = null; }
      return;
    }
    canvas.style.display = 'block';
    if (emptyEl) emptyEl.style.display = 'none';

    const hourData = Array(24).fill(null);
    hrData.forEach(h => { hourData[h.hour] = h.avg_bpm; });
    const labels = Array.from({length: 24}, (_, i) => i % 6 === 0 ? `${i}:00` : '');
    const valid  = hourData.filter(v => v !== null);
    const min    = Math.round(Math.min(...valid));
    const max    = Math.round(Math.max(...valid));
    const avg    = Math.round(valid.reduce((s,v) => s+v, 0) / valid.length);

    if (statsEl) statsEl.innerHTML = `
      <div class="hr-stat min"><span class="lbl">Min</span><span class="val">${min}<span class="u"> bpm</span></span></div>
      <div class="hr-stat avg"><span class="lbl">Ø Heute</span><span class="val">${avg}<span class="u"> bpm</span></span></div>
      <div class="hr-stat max"><span class="lbl">Max</span><span class="val">${max}<span class="u"> bpm</span></span></div>`;

    if (hrChartInstance) { hrChartInstance.destroy(); hrChartInstance = null; }
    const ctx2 = canvas.getContext('2d');
    const grad = ctx2.createLinearGradient(0, 0, 0, 130);
    grad.addColorStop(0, 'rgba(239,68,68,0.25)');
    grad.addColorStop(1, 'rgba(239,68,68,0.00)');
    hrChartInstance = new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          data: hourData,
          borderColor: '#ef4444',
          backgroundColor: grad,
          borderWidth: 1.8,
          pointRadius: 0,
          pointHoverRadius: 4,
          pointHoverBackgroundColor: '#fca5a5',
          pointHoverBorderColor: '#fff',
          pointHoverBorderWidth: 2,
          spanGaps: true,
          fill: true,
          tension: 0.45,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(14,14,18,0.96)',
            borderColor: 'rgba(190,195,215,0.18)',
            borderWidth: 1,
            titleColor: '#e8eaf0',
            bodyColor: '#e8eaf0',
            titleFont: { size: 11, weight: '700' },
            bodyFont: { size: 11 },
            padding: 8,
            displayColors: false,
            callbacks: {
              title: items => `${items[0].dataIndex}:00 Uhr`,
              label: ctx => `${Math.round(ctx.raw)} bpm`
            }
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(190,195,215,0.04)', drawTicks: false },
            border: { display: false },
            ticks: { color: 'rgba(200,205,220,0.40)', font: { size: 9, weight: '600' }, padding: 4 }
          },
          y: {
            grid: { color: 'rgba(190,195,215,0.04)', drawTicks: false },
            border: { display: false },
            ticks: { color: 'rgba(200,205,220,0.40)', font: { size: 9, weight: '600' }, padding: 4 },
            beginAtZero: false,
            suggestedMin: Math.max(40, min - 8),
            suggestedMax: max + 10
          }
        }
      }
    });
  } catch(e) {
    console.error('HR chart error:', e);
    canvas.style.display = 'none';
    if (emptyEl) { emptyEl.textContent = 'Fehler beim Laden'; emptyEl.style.display = 'block'; }
  }
}

// ══════════════════════════════════════════════════════
// APPLE HEALTH DATA (Morgen-Tab — Legacy, nicht mehr aktiv)
// ══════════════════════════════════════════════════════
async function loadHealthData() {
  const section = document.getElementById('health-section');
  const dateEl  = document.getElementById('health-date');
  if (!section) return;

  const c = getCfg();
  if (!c.url || !c.key) {
    section.innerHTML = `<div class="health-loading">Supabase nicht konfiguriert</div>`;
    return;
  }

  try {
    const today = new Date().toISOString().split('T')[0];
    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];

    const res = await fetch(
      `${c.url}/rest/v1/health_data?select=*&order=date.desc&limit=2`,
      { headers: { 'apikey': c.key, 'Authorization': `Bearer ${c.key}` } }
    );
    const rows = await res.json();
    const data = rows && rows.length > 0 ? rows[0] : null;

    if (!data) {
      section.innerHTML = `
        <div class="health-grid">
          ${healthTile('hrv',   '💚', null, '', 'HRV', 'Noch kein Eintrag')}
          ${healthTile('rhr',   '❤️', null, '', 'Herzfrequenz', 'Ruhepuls fehlt')}
          ${healthTile('sleep', '🌙', null, '', 'Schlaf', 'Daten fehlen')}
          ${healthTile('steps', '👟', null, '', 'Schritte', 'Daten fehlen')}
        </div>
        <div style="font-size:11px;color:var(--text-muted);text-align:center;padding:4px 0 8px;">
          Shortcut noch nicht eingerichtet
        </div>`;
      return;
    }

    const label = data.date === today ? 'Heute' : data.date === yesterday ? 'Gestern' : data.date;
    if (dateEl) dateEl.textContent = label;

    const hrv = data.hrv_ms;
    const sleep = data.sleep_hours;

    section.innerHTML = `
      <div class="health-grid">
        ${healthTile('hrv',   '💚',
            hrv ? Math.round(hrv) : null, hrv ? 'ms' : '',
            'HRV', !hrv ? 'Kein Wert' : hrv >= 60 ? '🟢 Erholt' : hrv >= 40 ? '🟡 Okay' : '🔴 Gestresst')}
        ${healthTile('rhr',   '❤️',
            data.rhr_bpm ? Math.round(data.rhr_bpm) : null, data.rhr_bpm ? 'bpm' : '',
            'Ruhepuls', data.rhr_bpm ? (data.rhr_bpm <= 60 ? '🟢 Top' : data.rhr_bpm <= 75 ? '🟡 Okay' : '🔴 Erhöht') : 'Kein Wert')}
        ${healthTile('sleep', '🌙',
            sleep ? (sleep / 60).toFixed(1) : null, sleep ? 'h' : '',
            'Schlaf', !sleep ? 'Kein Wert' : (sleep / 60) >= 7.5 ? '🟢 Top' : (sleep / 60) >= 6 ? '🟡 Okay' : '🔴 Zu wenig')}
        ${healthTile('steps', '👟',
            data.steps ? data.steps.toLocaleString('de-DE') : null, '',
            'Schritte', !data.steps ? 'Kein Wert' : data.steps >= 8000 ? '🟢 Aktiv' : '🟡 Wenig')}
        ${healthTile('hrv',   '🔥',
            data.active_energy ? Math.round(data.active_energy) : null, data.active_energy ? 'kcal' : '',
            'Aktive Kal.', !data.active_energy ? 'Kein Wert' : data.active_energy >= 400 ? '🟢 Top' : '🟡 Okay')}
        ${healthTile('sleep', '🫁',
            data.respiratory_rate ? data.respiratory_rate.toFixed(1) : null, data.respiratory_rate ? '/min' : '',
            'Atemfreq.', !data.respiratory_rate ? 'Kein Wert' : data.respiratory_rate >= 12 && data.respiratory_rate <= 20 ? '🟢 Normal' : '🟡 Check')}
        ${healthTile('steps', '⚡',
            data.exercise_minutes ? Math.round(data.exercise_minutes) : null, data.exercise_minutes ? 'min' : '',
            'Bewegung', !data.exercise_minutes ? 'Kein Wert' : data.exercise_minutes >= 30 ? '🟢 Top' : '🟡 Wenig')}
      </div>`;
  } catch (e) {
    console.error('Health fetch error:', e);
    section.innerHTML = `<div class="health-loading">Fehler beim Laden</div>`;
  }
}

function healthTile(cls, icon, val, unit, label, sub) {
  const noData = val === null || val === undefined;
  return `
    <div class="health-tile ${cls}${noData ? ' no-data' : ''}">
      <div class="health-tile-icon">${icon}</div>
      <div class="health-tile-val">${noData ? '—' : val}${!noData && unit ? `<span class="unit">${unit}</span>` : ''}</div>
      <div class="health-tile-label">${label}</div>
      <div class="health-tile-sub">${sub}</div>
    </div>`;
}

// ══════════════════════════════════════════════════════
// NAV
// ══════════════════════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll('.tab-view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(`tab-${tab}`).classList.add('active');
  document.querySelector(`.nav-btn[data-tab="${tab}"]`).classList.add('active');
  if (tab === 'gesundheit') loadGesundheitTab();
  if (tab === 'morgen') { renderTodos(); renderHeatmap(); }
  if (tab === 'plan') renderPlan();
  if (tab === 'abend') initSliders();
  if (tab === 'workout') {
    const banner = document.getElementById('acl-banner');
    if (banner) banner.style.display = S.wo_current==='Legs' ? 'block' : 'none';
  }
}

// ══════════════════════════════════════════════════════
// MORGEN — Greeting & Weather
// ══════════════════════════════════════════════════════
function renderGreeting() {
  const h = new Date().getHours();
  const greetings = [
    [5,10,'Guten Morgen, Samuel 🌅','Mach den ersten Move.'],
    [10,14,'Vormittag ⚡','Bleib scharf.'],
    [14,18,'Nachmittag 🎯','Deep Work Zeit.'],
    [18,22,'Guten Abend 🌙','Wie war der Tag?'],
    [22,24,'Noch wach 👀','Morgen früh aufstehen lohnt sich.'],
    [0,5,'Sehr spät 🌙','Schlaf gut, morgen neu.']
  ];
  const [,,g,s] = greetings.find(([a,b])=>h>=a&&h<b)||greetings[0];
  document.getElementById('greeting').textContent = g;
  document.getElementById('greeting-sub').textContent = s;
}

async function loadWeather() {
  try {
    const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude=48.73&longitude=11.19&current_weather=true&timezone=Europe/Berlin');
    const d = await r.json();
    const w = d.current_weather;
    const icons = {0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',61:'🌧',71:'🌨',80:'🌦',95:'⛈'};
    const icon = icons[w.weathercode]||'🌡';
    document.getElementById('weather-widget').innerHTML = `${icon} ${Math.round(w.temperature)}°C · ${w.windspeed} km/h Wind`;
  } catch(e){}
}

// ══════════════════════════════════════════════════════
// QUOTE OF THE DAY
// ══════════════════════════════════════════════════════
function renderQuote() {
  const el = document.getElementById('qotd-text');
  if (!el) return;
  const dayOfYear = Math.floor((new Date()-new Date(new Date().getFullYear(),0,0))/86400000);
  dbRead('quotes_custom').then(customQ => {
    const pool = (customQ && customQ.length > 0) ? customQ : QUOTES_LOCAL;
    el.textContent = '"' + pool[dayOfYear % pool.length] + '"';
  });
  // Also update desktop quote banner
  const banner = document.getElementById('quote-banner');
  if (banner) banner.textContent = '"' + QUOTES_LOCAL[dayOfYear % QUOTES_LOCAL.length] + '"';
}

// ══════════════════════════════════════════════════════
// HEATMAP
// ══════════════════════════════════════════════════════
async function renderHeatmap() {
  const el = document.getElementById('habit-heatmap');
  if (!el) return;
  el.innerHTML = '';
  const checkCount = ROUTINE.filter(x=>x.type==='check').length || 5;
  for (let i = 29; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate()-i);
    const key = d.toISOString().split('T')[0];
    const data = await dbRead(`r_${key}`);
    const doneCount = data ? Object.values(data).filter(Boolean).length : 0;
    const intensity = checkCount > 0 ? doneCount/checkCount : 0;
    const cls = i === 0 ? 'today' : intensity > 0.6 ? 'done' : intensity > 0 ? 'done' : 'miss';
    const cell = document.createElement('span');
    cell.className = `hm-dot ${cls}`;
    cell.title = key;
    el.appendChild(cell);
  }
}

// ══════════════════════════════════════════════════════
// MORGEN — Ring & Routine
// ══════════════════════════════════════════════════════
function renderDate() {
  const d = new Date();
  document.getElementById('today-date').textContent = d.toLocaleDateString('de-DE', {weekday:'long',day:'numeric',month:'long'});
}

function updateMorningRing() {
  const total = ROUTINE.length;
  const done = ROUTINE.filter((_,i) => S.routine[i]).length;
  const circ = 2 * Math.PI * 22;
  const fill = document.getElementById('ring-fill');
  fill.style.strokeDasharray = circ;
  fill.style.strokeDashoffset = circ - (done/total) * circ;
  fill.style.stroke = done === total ? 'var(--green)' : 'var(--accent)';
  document.getElementById('ring-num').textContent = `${done}/${total}`;
  const checkDone = ROUTINE.filter((x, i) => x.type === 'check' && S.routine[i]).length;
  const checkTotal = ROUTINE.filter(x => x.type === 'check').length;
  const mc = document.getElementById('morning-complete');
  if (checkDone === checkTotal && checkTotal > 0 && !mc.classList.contains('show')) {
    mc.classList.add('show'); checkMorningComplete();
  } else if (checkDone < checkTotal) mc.classList.remove('show');
}

function renderRoutineList() {
  const c = document.getElementById('routine-list');
  c.innerHTML = '';
  ROUTINE.forEach((item, idx) => {
    const done = !!S.routine[idx];
    if (!TS[idx]) TS[idx] = {active:false, remaining: item.type==='timer' ? item.duration*60 : 0, open:false, interval:null};
    const div = document.createElement('div');
    div.className = `ri${done ? ' done' : ''}`;
    div.id = `ri-${idx}`;

    if (item.type === 'check') {
      div.onclick = () => toggleCheck(idx);
      div.innerHTML = `
        <div class="ri-em">${item.em}</div>
        <div class="ri-body"><div class="ri-title">${item.tx}</div><div class="ri-hint">${item.ht}</div></div>
        <div class="ri-check">${done ? '✓' : ''}</div>`;
    } else {
      const ts = TS[idx];
      const circ = 2 * Math.PI * 50;
      const total = item.duration * 60;
      const offset = circ * (ts.remaining / total);
      div.innerHTML = `
        <div class="ri-em">${item.em}</div>
        <div class="ri-body">
          <div class="ri-title">${item.tx}</div>
          <div class="ri-hint">${item.ht}</div>
          <div class="ri-timer-area${ts.open ? ' open' : ''}" id="ta-${idx}">
            <div class="timer-ring-wrap">
              <svg width="120" height="120" viewBox="0 0 120 120">
                <circle cx="60" cy="60" r="50" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6"/>
                <circle id="tarc-${idx}" cx="60" cy="60" r="50" fill="none"
                  stroke="${done ? 'var(--green)' : 'var(--blue)'}" stroke-width="6" stroke-linecap="round"
                  stroke-dasharray="${circ}" stroke-dashoffset="${done ? 0 : offset}"/>
              </svg>
              <div class="timer-cd" id="tcd-${idx}" style="${done ? 'color:var(--green)' : ''}">${done ? '✓' : fmtTime(ts.remaining)}</div>
            </div>
            <div class="timer-controls">
              <button class="tbtn ${ts.active ? 'pause' : 'start'}" id="tstart-${idx}" onclick="timerToggle(${idx})">${ts.active ? '⏸ Pause' : '▶ Start'}</button>
              <button class="tbtn reset" onclick="timerReset(${idx})">↺ Reset</button>
            </div>
          </div>
        </div>
        <div class="ri-check" style="${done ? 'background:var(--indigo);border-color:var(--indigo);' : ''}" onclick="toggleTimerOpen(${idx})">${done ? '✓' : '▶'}</div>`;
    }
    c.appendChild(div);
  });
  updateMorningRing();
}

function toggleCheck(idx) {
  S.routine[idx] = !S.routine[idx];
  upsert(`r_${TODAY}`, S.routine);
  playSound('check');
  renderRoutineList();
}

function toggleTimerOpen(idx) {
  TS[idx].open = !TS[idx].open;
  const a = document.getElementById(`ta-${idx}`);
  if (a) a.classList.toggle('open', TS[idx].open);
}

function fmtTime(s) { return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`; }

function timerToggle(idx) {
  const ts = TS[idx];
  if (ts.active) {
    clearInterval(ts.interval); ts.active = false;
    const b = document.getElementById(`tstart-${idx}`);
    if (b) { b.textContent = '▶ Start'; b.className = 'tbtn start'; }
  } else {
    ts.active = true;
    ts.interval = setInterval(() => timerTick(idx), 1000);
    const b = document.getElementById(`tstart-${idx}`);
    if (b) { b.textContent = '⏸ Pause'; b.className = 'tbtn pause'; }
  }
}

function timerTick(idx) {
  const ts = TS[idx]; const item = ROUTINE[idx];
  if (ts.remaining <= 0) { timerDone(idx); return; }
  ts.remaining--;
  const circ = 2 * Math.PI * 50; const total = item.duration * 60;
  const cd = document.getElementById(`tcd-${idx}`); const arc = document.getElementById(`tarc-${idx}`);
  if (cd) cd.textContent = fmtTime(ts.remaining);
  if (arc) arc.style.strokeDashoffset = circ * (ts.remaining / total);
}

function timerDone(idx) {
  const ts = TS[idx];
  clearInterval(ts.interval); ts.active = false; ts.remaining = 0;
  S.routine[idx] = true;
  upsert(`r_${TODAY}`, S.routine);
  const arc = document.getElementById(`tarc-${idx}`); const cd = document.getElementById(`tcd-${idx}`);
  if (arc) { arc.style.stroke = 'var(--green)'; arc.style.strokeDashoffset = 0; }
  if (cd) { cd.textContent = '✓'; cd.style.color = 'var(--green)'; }
  const ri = document.getElementById(`ri-${idx}`);
  if (ri) {
    ri.classList.add('done');
    const chk = ri.querySelector('.ri-check');
    if (chk) { chk.style.background='var(--indigo)'; chk.style.borderColor='var(--indigo)'; chk.textContent='✓'; chk.style.color='white'; }
  }
  if (navigator.vibrate) navigator.vibrate([200,100,200]);
  playSound('check');
  updateMorningRing();
}

function timerReset(idx) {
  const ts = TS[idx]; const item = ROUTINE[idx];
  clearInterval(ts.interval); ts.active = false; ts.remaining = item.duration * 60;
  const circ = 2 * Math.PI * 50;
  const cd = document.getElementById(`tcd-${idx}`); const arc = document.getElementById(`tarc-${idx}`); const b = document.getElementById(`tstart-${idx}`);
  if (cd) { cd.textContent = fmtTime(ts.remaining); cd.style.color = 'var(--blue)'; }
  if (arc) { arc.style.stroke = 'var(--blue)'; arc.style.strokeDashoffset = circ; }
  if (b) { b.textContent = '▶ Start'; b.className = 'tbtn start'; }
}

// ══════════════════════════════════════════════════════
// WORKOUT — SESSION MANAGEMENT
// ══════════════════════════════════════════════════════
function initWorkoutSession() {
  const split = S.wo_current;
  const plan = getPlan()[split] || [];
  S.wo_session = {
    split,
    exercises: plan.map(ex => ({
      planId: ex.id,
      name: ex.name,
      targetKg: ex.kg,
      targetSets: ex.sets,
      targetReps: ex.reps,
      bw: !!ex.bw,
      setCount: ex.sets,
      sets: [],
      note: '',
      noteOpen: false,
      sessionMod: null,
    })),
    sessionNote: '',
    pendingPlanChanges: [],
  };
  upsert(`wo_session_${TODAY}`, S.wo_session);
}

function ensureSession() {
  if (!S.wo_session || !S.wo_session.split || S.wo_session.split !== S.wo_current || !Array.isArray(S.wo_session.exercises)) {
    initWorkoutSession();
  }
}

function saveSession() { upsert(`wo_session_${TODAY}`, S.wo_session); }

// ══════════════════════════════════════════════════════
// WORKOUT — RENDER
// ══════════════════════════════════════════════════════
function renderWorkout() {
  ensureSession();
  const split = S.wo_current;
  const rot = ['Pull','Push','Legs'];
  const ci = rot.indexOf(split);
  document.getElementById('wo-split').textContent = split;
  const rotEl = document.getElementById('wo-rotation');
  rotEl.innerHTML = [rot[(ci+2)%3],'·',split,'·',rot[(ci+1)%3]].map((t,i)=>i===2?`<span class="now">${t}</span>`:`<span>${t}</span>`).join('');
  const ld = localStorage.getItem('wo_last_date');
  document.getElementById('wo-last-date').textContent = ld ? `Letztes Training · ${ld}` : 'Noch kein Workout geloggt';
  const banner = document.getElementById('acl-banner');
  if (banner) banner.style.display = split==='Legs' ? 'block' : 'none';

  const c = document.getElementById('exercise-list');
  c.innerHTML = '';
  const exs = S.wo_session.exercises || [];
  const RIR = {clean:['✅','Clean'],'1-2':['🔥','1–2 RIR'],hard:['⚡','Hart'],fail:['💀','Failure']};
  const CIRC = 125.66;

  exs.forEach((ex, ei) => {
    const sc = ex.setCount || ex.targetSets || 3;
    const sets = ex.sets || [];
    const loggedCount = sets.slice(0, sc).filter(s => s != null).length;
    const allDone = loggedCount >= sc && sc > 0;
    const inProgress = loggedCount > 0 && !allDone;
    const rec = (S.wo_records || {})[ex.name];
    const isExtra = ex.planId === null;

    // Progress ring
    const ringColor = allDone ? 'var(--green)' : (inProgress ? 'rgba(190,195,215,0.85)' : 'rgba(190,195,215,0.10)');
    const ringOffset = sc > 0 ? CIRC - (loggedCount/sc)*CIRC : CIRC;
    const ringTxt = allDone ? '✓' : `${loggedCount}/${sc}`;
    const ringTrackColor = allDone ? 'rgba(16,185,129,0.20)' : 'rgba(190,195,215,0.10)';
    const ringGlow = allDone ? 'rgba(16,185,129,0.4)' : 'rgba(190,195,215,0.3)';
    const ringFill = (allDone || inProgress) ? `<circle cx="24" cy="24" r="20" fill="none" stroke="${ringColor}" stroke-width="4" stroke-dasharray="${CIRC}" stroke-dashoffset="${ringOffset.toFixed(2)}" stroke-linecap="round" style="filter:drop-shadow(0 0 4px ${ringGlow});"/>` : '';
    const ringHtml = `<div class="ex-ring"><svg width="48" height="48"><circle cx="24" cy="24" r="20" fill="none" stroke="${ringTrackColor}" stroke-width="4"/>${ringFill}</svg><div class="ex-ring-center">${ringTxt}</div></div>`;

    // Set tiles
    let tilesHtml = '';
    for (let s = 0; s < sc; s++) {
      const sd = sets[s];
      const logged = sd != null;
      const isPR = logged && !sd.bw && rec && sd.kg > (rec.kg||0);
      const kgTxt = logged ? (sd.bw ? 'BW' : sd.kg) : (ex.bw ? 'BW' : (ex.targetKg ?? '?'));
      const repsTxt = logged ? (sd.reps === 'F' ? 'Fail' : `×${sd.reps}`) : (ex.targetReps ? `×${ex.targetReps}` : '—');
      const rirTxt = logged && sd.rir ? (RIR[sd.rir]?.[0] || '') : '';
      tilesHtml += `<button class="set-tile${logged?' logged':''}" onclick="openModal(${ei},${s})">
        <div class="st-num">S${s+1}</div>
        ${isPR ? '<div class="st-pr">PR</div>' : ''}
        <div class="st-kg">${kgTxt}${logged && !sd.bw ? '<span class="u">kg</span>' : ''}</div>
        <div class="st-reps">${repsTxt}</div>
        ${rirTxt ? `<div class="st-rir">${rirTxt}</div>` : ''}
      </button>`;
    }
    tilesHtml += `<button class="set-tile add" onclick="event.stopPropagation();addSet(${ei})">+</button>`;

    // RIR panel
    const rirOpen = ex.rirPanelOpen != null;
    const lastSi = ex.rirPanelOpen;
    const lastSd = rirOpen ? (sets[lastSi] || null) : null;
    const rirPanelHtml = rirOpen ? `<div class="rir-panel">
      <div class="rir-label">Wie war Satz ${lastSi+1}?</div>
      <div class="rir-grid">${Object.entries(RIR).map(([k,[em,lbl]])=>`<button class="rir-btn${lastSd&&lastSd.rir===k?' active':''}" onclick="setRir(${ei},${lastSi},'${k}')"><div class="rb-em">${em}</div><div class="rb-lbl">${lbl}</div></button>`).join('')}</div>
      <button class="rir-done" onclick="dismissRirPanel(${ei})">FERTIG</button>
    </div>` : '';

    // Note
    const noteHasContent = !!ex.note;
    const noteLbl = noteHasContent ? (ex.note.length>40?ex.note.slice(0,40)+'…':ex.note) : 'Note / next session…';
    const noteHtml = `<button class="ex-note${noteHasContent?' filled':''}" onclick="event.stopPropagation();toggleNote(${ei})"><span>📝</span> ${noteLbl}</button>
      <textarea class="ex-note-textarea${ex.noteOpen?' open':''}" id="note-input-${ei}" oninput="event.stopPropagation();scheduleNoteSave(${ei})">${ex.note||''}</textarea>`;

    const card = document.createElement('div');
    card.className = `ex-card${allDone?' done':inProgress?' progress':''}`;
    card.innerHTML = `
      <div class="ex-top">
        ${ringHtml}
        <div style="flex:1;min-width:0;">
          <div class="ex-name">${ex.name}${isExtra?'<span style="font-size:9px;color:var(--amber);margin-left:5px;font-weight:700;vertical-align:middle;">EXTRA</span>':''}</div>
          <div class="ex-meta">${ex.targetKg??'—'} kg · ${ex.targetReps||'—'} Reps · ${sc}×</div>
        </div>
        <button class="ex-menu" onclick="event.stopPropagation();openExEdit(${ei})">⋯</button>
      </div>
      <div class="tile-grid">${tilesHtml}</div>
      ${rirPanelHtml}
      ${noteHtml}`;

    c.appendChild(card);
  });

  // Session note
  const sn = S.wo_session.sessionNote || '';
  const snDiv = document.createElement('div');
  snDiv.className = 'session-note-card';
  snDiv.innerHTML = `<button class="ex-note${sn?' filled':''}" onclick="document.getElementById('session-note-input').classList.toggle('open')"><span>📋</span> ${sn?(sn.slice(0,48)+(sn.length>48?'…':'')):'Session Note / Workout-Notiz'}</button>
    <textarea class="ex-note-textarea${sn?' open':''}" id="session-note-input" oninput="scheduleSessionNoteSave()">${sn}</textarea>`;
  c.appendChild(snDiv);

  const addBtn = document.createElement('button');
  addBtn.className = 'extra-ex-btn';
  addBtn.textContent = '+ Weitere Übung';
  addBtn.onclick = openExtraExModal;
  c.appendChild(addBtn);

  renderWorkoutHistory();
}

// ══════════════════════════════════════════════════════
// SET OPERATIONS
// ══════════════════════════════════════════════════════
function addSet(ei) {
  const ex = S.wo_session.exercises[ei]; if (!ex) return;
  ex.setCount = (ex.setCount || ex.targetSets || 3) + 1;
  saveSession(); renderWorkout();
}
function removeSet(ei, si) {
  const ex = S.wo_session.exercises[ei]; if (!ex) return;
  if (!ex.sets) ex.sets = [];
  ex.sets.splice(si, 1);
  ex.setCount = Math.max(0, (ex.setCount||1) - 1);
  saveSession(); renderWorkout();
}
function setRir(ei, si, rir) {
  const ex = S.wo_session.exercises[ei];
  if (!ex || !ex.sets[si]) return;
  ex.sets[si].rir = ex.sets[si].rir === rir ? null : rir;
  saveSession(); renderWorkout();
}
function reorderEx(ei, dir) {
  const exs = S.wo_session.exercises;
  const ti = ei + dir;
  if (ti < 0 || ti >= exs.length) return;
  [exs[ei], exs[ti]] = [exs[ti], exs[ei]];
  saveSession(); renderWorkout();
}

// ══════════════════════════════════════════════════════
// NOTES
// ══════════════════════════════════════════════════════
function toggleNote(ei) {
  const ex = S.wo_session.exercises[ei]; if (!ex) return;
  ex.noteOpen = !ex.noteOpen;
  const ta = document.getElementById(`note-input-${ei}`);
  if (ta) ta.classList.toggle('open', ex.noteOpen);
}
const noteSaveTimers = {};
function scheduleNoteSave(ei) {
  clearTimeout(noteSaveTimers[ei]);
  noteSaveTimers[ei] = setTimeout(() => {
    const ta = document.getElementById(`note-input-${ei}`); if (!ta) return;
    S.wo_session.exercises[ei].note = ta.value;
    saveSession();
    const sv = document.getElementById(`note-saved-${ei}`);
    if (sv) { sv.classList.add('show'); setTimeout(()=>sv.classList.remove('show'), 1500); }
  }, 700);
}
let sessionNoteTimer;
function scheduleSessionNoteSave() {
  clearTimeout(sessionNoteTimer);
  sessionNoteTimer = setTimeout(() => {
    const ta = document.getElementById('session-note-input');
    if (ta) { S.wo_session.sessionNote = ta.value; saveSession(); }
  }, 700);
}

// ══════════════════════════════════════════════════════
// EXERCISE EDIT MODAL (✏️ button or long press)
// ══════════════════════════════════════════════════════
let editingExIdx = null;
let editState = {};
function openExEdit(ei) {
  editingExIdx = ei;
  const ex = S.wo_session.exercises[ei];
  editState = { setCount: ex.setCount || ex.targetSets || 3, kg: ex.targetKg || 0, bw: ex.bw || false };
  document.getElementById('ex-edit-name').textContent = ex.name;
  document.getElementById('ex-edit-setcount').textContent = editState.setCount;
  updateExEditKg();
  document.getElementById('ex-edit-note').value = ex.sessionMod || '';
  document.getElementById('ex-edit-overlay').classList.add('open');
  document.getElementById('ex-edit-modal').classList.add('open');
}
function updateExEditKg() {
  const el = document.getElementById('ex-edit-kg');
  if (el) el.textContent = editState.bw ? 'BW' : `${editState.kg} kg`;
}
function editSetCount(d) {
  editState.setCount = Math.max(1, editState.setCount + d);
  document.getElementById('ex-edit-setcount').textContent = editState.setCount;
}
function editTargetKg(d) {
  if (editState.bw) return;
  editState.kg = Math.round((editState.kg + d) * 4) / 4;
  if (editState.kg < 0) editState.kg = 0;
  updateExEditKg();
}
function closeExEdit() {
  document.getElementById('ex-edit-overlay').classList.remove('open');
  document.getElementById('ex-edit-modal').classList.remove('open');
  editingExIdx = null;
}
function saveExEdit() {
  const ei = editingExIdx; if (ei === null) return;
  const ex = S.wo_session.exercises[ei];
  const note = document.getElementById('ex-edit-note').value.trim();
  const mods = [];
  if (editState.setCount !== ex.setCount) mods.push(`Sätze ${ex.setCount}→${editState.setCount}`);
  if (!editState.bw && editState.kg !== ex.targetKg) mods.push(`Gewicht ${ex.targetKg}→${editState.kg} kg`);
  ex.setCount = editState.setCount;
  if (!editState.bw) ex.targetKg = editState.kg;
  ex.sessionMod = [note, ...mods].filter(Boolean).join(' | ') || null;
  if (mods.length || note) {
    if (!S.wo_session.pendingPlanChanges) S.wo_session.pendingPlanChanges = [];
    S.wo_session.pendingPlanChanges.push({ exName: ex.name, mods, note, date: TODAY });
    upsert('wo_pending_changes', S.wo_session.pendingPlanChanges);
  }
  saveSession(); closeExEdit(); renderWorkout();
}

// ══════════════════════════════════════════════════════
// EXTRA EXERCISE MODAL
// ══════════════════════════════════════════════════════
let extraState = { kg: 0, sets: 3 };
function openExtraExModal() {
  extraState = { kg: 0, sets: 3 };
  document.getElementById('extra-ex-name-input').value = '';
  document.getElementById('extra-ex-name-input').classList.remove('error');
  document.getElementById('extra-ex-kg-disp').textContent = '0 kg';
  document.getElementById('extra-ex-sets-disp').textContent = '3';
  document.getElementById('extra-ex-overlay').classList.add('open');
  document.getElementById('extra-ex-modal').classList.add('open');
  setTimeout(()=>document.getElementById('extra-ex-name-input').focus(), 350);
}
function closeExtraEx() {
  document.getElementById('extra-ex-overlay').classList.remove('open');
  document.getElementById('extra-ex-modal').classList.remove('open');
}
function adjustExtraKg(d) {
  extraState.kg = Math.max(0, Math.round((extraState.kg + d) * 4) / 4);
  document.getElementById('extra-ex-kg-disp').textContent = `${extraState.kg} kg`;
}
function adjustExtraSets(d) {
  extraState.sets = Math.max(1, extraState.sets + d);
  document.getElementById('extra-ex-sets-disp').textContent = extraState.sets;
}
function addExtraExercise() {
  const nameEl = document.getElementById('extra-ex-name-input');
  const name = nameEl.value.trim();
  if (!name) { nameEl.classList.add('error'); return; }
  S.wo_session.exercises.push({
    planId: null, name,
    targetKg: extraState.kg, targetSets: extraState.sets, targetReps: '—',
    bw: extraState.kg === 0, setCount: extraState.sets,
    sets: [], note: '', noteOpen: false, sessionMod: null,
  });
  saveSession(); closeExtraEx(); renderWorkout(); playSound('check');
}

// ══════════════════════════════════════════════════════
// SET MODAL (weight + reps per set)
// ══════════════════════════════════════════════════════
let modalState = { ei: null, si: null, kg: 0, reps: 10, bw: false };
function openModal(ei, si) {
  const ex = S.wo_session.exercises[ei];
  const sets = ex.sets || [];
  const sd = sets[si];
  const prev = si > 0 ? sets[si-1] : null;
  let kg = 0, bw = !!ex.bw;
  if (sd != null) { bw = !!sd.bw; kg = sd.kg || 0; }
  else if (prev != null && !prev.bw) { kg = prev.kg || 0; bw = false; }
  else { kg = ex.targetKg || 0; bw = !!ex.bw; }
  const rTarget = String(ex.targetReps||'10').split('–')[0].replace(/\D/g,'');
  let reps = sd != null ? (sd.reps === 'F' ? 'F' : (sd.reps||10)) : (parseInt(rTarget)||10);
  modalState = { ei, si, kg, reps, bw };
  document.getElementById('modal-set-lbl').textContent = `Set ${si+1}`;
  document.getElementById('modal-ex-nm').textContent = ex.name;
  updateWeightDisplay(); updateRepsDisplay();
  renderWeightChips(ex, kg, bw); renderRepsChips(reps);
  checkPR(ex);
  document.getElementById('modal-overlay').classList.add('open');
  document.getElementById('wo-modal').classList.add('open');
}
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.getElementById('wo-modal').classList.remove('open');
}
function updateWeightDisplay() {
  const el = document.getElementById('modal-weight'); if (!el) return;
  el.innerHTML = modalState.bw ? 'BW' : `${modalState.kg}<span class="modal-val-unit"> kg</span>`;
}
function updateRepsDisplay() {
  const el = document.getElementById('modal-reps'); if (!el) return;
  el.textContent = modalState.reps === 'F' ? 'Fail' : modalState.reps;
}
function renderWeightChips(ex, curKg, isBw) {
  const cc = document.getElementById('weight-chips'); cc.innerHTML = '';
  const chips = [];
  if (ex.bw) chips.push('BW');
  if (!isBw && curKg > 0) {
    [-10,-7.5,-5,-2.5,0,2.5,5,7.5,10].forEach(d => {
      const v = Math.round((curKg+d)*4)/4; if (v>0) chips.push(v);
    });
  } else if (!isBw) { [2.5,5,7.5,10,12.5,15,17.5,20,25,30,40,50,60,70,80].forEach(v=>chips.push(v)); }
  const seen = new Set();
  chips.forEach(v => {
    if (seen.has(String(v))) return; seen.add(String(v));
    const isActive = v==='BW' ? isBw : (v===curKg && !isBw);
    const ch = document.createElement('button');
    ch.className = 'chip'+(isActive?' active':'');
    ch.textContent = v==='BW'?'BW':`${v}`;
    ch.onclick = () => {
      cc.querySelectorAll('.chip').forEach(c=>c.classList.remove('active')); ch.classList.add('active');
      if (v==='BW'){modalState.bw=true;modalState.kg=0;}else{modalState.bw=false;modalState.kg=v;}
      updateWeightDisplay(); checkPR(S.wo_session.exercises[modalState.ei]);
    };
    cc.appendChild(ch);
  });
}
function renderRepsChips(cur) {
  const cc = document.getElementById('quick-chips'); cc.innerHTML = '';
  ['3','4','5','6','7','8','10','12','15','F'].forEach(v => {
    const val = v==='F'?'F':parseInt(v);
    const ch = document.createElement('button');
    ch.className = 'chip'+(String(cur)===String(val)?' active':'');
    ch.textContent = v;
    ch.onclick = () => {
      cc.querySelectorAll('.chip').forEach(c=>c.classList.remove('active')); ch.classList.add('active');
      modalState.reps = val; updateRepsDisplay(); checkPR(S.wo_session.exercises[modalState.ei]);
    };
    cc.appendChild(ch);
  });
}
function adjustWeight(d) {
  if (modalState.bw) return;
  modalState.kg = Math.max(0, Math.round((modalState.kg+d)*4)/4);
  updateWeightDisplay();
  document.querySelectorAll('#weight-chips .chip').forEach(c=>c.classList.remove('active'));
  checkPR(S.wo_session.exercises[modalState.ei]);
}
function adjustReps(d) {
  if (modalState.reps==='F') modalState.reps=15;
  else modalState.reps = Math.max(1, (parseInt(modalState.reps)||1)+d);
  updateRepsDisplay();
  document.querySelectorAll('#quick-chips .chip').forEach(c=>{
    c.classList.toggle('active', c.textContent===String(modalState.reps));
  });
  checkPR(S.wo_session.exercises[modalState.ei]);
}
function checkPR(ex) {
  const el = document.getElementById('modal-pr'); if (!el) return;
  if (modalState.bw || modalState.reps==='F') { el.textContent=''; return; }
  const rec = (S.wo_records||{})[ex?.name];
  if (!rec) { el.textContent=''; return; }
  el.textContent = (modalState.kg>rec.kg||(modalState.kg>=rec.kg&&modalState.reps>rec.reps))
    ? '🏆 Neuer Rekord!' : `Aktuell: ${rec.kg} kg × ${rec.reps}`;
}
function confirmSet() {
  const {ei, si, kg, reps, bw} = modalState;
  const ex = S.wo_session.exercises[ei];
  if (!ex.sets) ex.sets = [];
  ex.sets[si] = { kg, reps, bw, rir: null };
  if (!bw && reps!=='F') {
    if (!S.wo_records) S.wo_records = {};
    const rec = S.wo_records[ex.name];
    if (!rec || kg>rec.kg || (kg>=rec.kg && reps>rec.reps)) {
      S.wo_records[ex.name] = { kg, reps, date: TODAY };
      upsert('wo_records', S.wo_records);
    }
  }
  ex.rirPanelOpen = si;
  saveSession(); playSound('check'); closeModal(); renderWorkout();
}

function dismissRirPanel(ei) {
  const ex = S.wo_session.exercises[ei]; if (!ex) return;
  delete ex.rirPanelOpen;
  saveSession(); renderWorkout();
}

// ══════════════════════════════════════════════════════
// KNEE PAIN (Legs-Tab)
// ══════════════════════════════════════════════════════
function logKneePain(val) {
  document.querySelectorAll('.knee-btn').forEach(b=>{
    b.style.background = +b.dataset.val===val ? 'rgba(245,158,11,0.3)' : 'rgba(245,158,11,0.05)';
  });
  upsert(`knee_pain_${TODAY}`, val);
  playSound('check');
}

document.getElementById('wo-finish-btn').onclick = async () => {
  const split = S.wo_current;
  const exs = S.wo_session.exercises || [];
  const lines = [`🏋️ ${split.toUpperCase()} — ${TODAY}`];
  exs.forEach((ex, i) => {
    const logged = (ex.sets||[]).filter(s=>s!=null);
    const setSummary = logged.map(s => {
      const w = s.bw ? 'BW' : `${s.kg}kg`;
      const r = s.reps==='F' ? 'Fail' : `${s.reps}×`;
      const rir = s.rir ? ` (${s.rir})` : '';
      return `${w}${r}${rir}`;
    }).join(' / ');
    lines.push(`${i+1}. ${ex.name}: ${setSummary||'—'}`);
    if (ex.note) lines.push(`   💬 ${ex.note}`);
  });
  if (S.wo_session.sessionNote) lines.push(`\n📋 ${S.wo_session.sessionNote}`);
  const text = lines.join('\n');
  try { await navigator.clipboard.writeText(text); } catch(e) { prompt('Training Log:', text); }
  const fb = document.getElementById('wo-copy-fb');
  fb.classList.add('show'); setTimeout(()=>fb.classList.remove('show'), 2500);
  const prevDate = localStorage.getItem('wo_last_date');
  const prevStreak = await dbRead('gym_streak')||0;
  const yest = new Date(); yest.setDate(yest.getDate()-1);
  const newStreak = prevDate===TODAY?prevStreak:prevDate===yest.toISOString().split('T')[0]?prevStreak+1:1;
  await upsert('gym_streak', newStreak);
  const gymEl = document.getElementById('gym-streak-counter');
  if (gymEl) gymEl.textContent = newStreak;
  const rot = ['Pull','Push','Legs'];
  S.wo_last = split; S.wo_current = rot[(rot.indexOf(split)+1)%3];
  localStorage.setItem('wo_last_date', TODAY);
  await upsert('wo_last', S.wo_last); await upsert('wo_current', S.wo_current);
  saveWorkoutToHistory(S.wo_session, split);

  // ── Update wo_plan with actually used weights ──
  if (WP && WP[split]) {
    let planUpdated = false;
    exs.forEach(ex => {
      if (ex.bw) return; // bodyweight — kein Gewicht zu updaten
      const logged = (ex.sets||[]).filter(s => s != null && !s.bw && s.kg > 0);
      if (!logged.length) return;
      const maxKg = Math.max(...logged.map(s => s.kg));
      const planEx = WP[split].find(p => p.id === ex.planId);
      if (planEx && maxKg !== planEx.kg) {
        planEx.kg = maxKg;
        planUpdated = true;
      }
    });
    if (planUpdated) await upsert('wo_plan', WP);
  }

  // ── Save notes for Claude coaching review ──
  const notesForReview = [];
  exs.forEach(ex => {
    if (ex.note && ex.note.trim()) {
      notesForReview.push({ date: TODAY, split, exercise: ex.name, note: ex.note.trim() });
    }
  });
  if (S.wo_session.sessionNote && S.wo_session.sessionNote.trim()) {
    notesForReview.push({ date: TODAY, split, exercise: 'SESSION', note: S.wo_session.sessionNote.trim() });
  }
  if (notesForReview.length) {
    const existing = await dbRead('wo_unreviewed_notes') || [];
    await upsert('wo_unreviewed_notes', [...existing, ...notesForReview]);
  }

  const sessionSnapshot = JSON.parse(JSON.stringify(S.wo_session));
  await upsert(`wo_session_${TODAY}`, { ...sessionSnapshot, done:true, ts: new Date().toISOString() });
  S.wo_session = {};
  playSound('milestone'); renderWorkout();
};

// ══════════════════════════════════════════════════════
// 75 HARD TAB
// ══════════════════════════════════════════════════════
function updateH75Ring(dayNum) {
  const circumference = 490.1;
  const offset = circumference - (dayNum/75)*circumference;
  const ring = document.getElementById('h75-ring');
  const label = document.getElementById('h75-ring-day');
  if (ring) { ring.style.strokeDashoffset = Math.max(0, offset); ring.style.stroke = dayNum>=50 ? 'var(--green)' : 'rgba(190,195,215,0.85)'; }
  if (label) label.textContent = dayNum;
  const milestoneMap = {1:"🚀 Los geht's!", 7:'🔥 1 Woche durch!', 21:'💪 21 Tage — Gewohnheit geformt!', 37:'⚡ Halbzeit!', 50:'🌟 Tag 50 — du bist nicht mehr derselbe!', 75:'🏆 75 HARD COMPLETE'};
  const msEl = document.getElementById('h75-milestone');
  if (msEl) msEl.textContent = milestoneMap[dayNum] || '';
}

function renderH75() {
  const h75 = S.h75;
  let dayNum = 0;
  if (h75.start) {
    dayNum = Math.max(0, Math.min(75, Math.floor((new Date(TODAY) - new Date(h75.start)) / 86400000) + 1));
  }
  updateH75Ring(dayNum);

  const dotsEl = document.getElementById('streak-dots');
  dotsEl.innerHTML = '';
  for (let i = 6; i >= 0; i--) {
    const d = new Date(TODAY); d.setDate(d.getDate() - i);
    const dk = d.toISOString().slice(0,10);
    const checks = (h75.days||{})[dk] || {};
    const allDone = H75_TASKS.length > 0 && Object.values(checks).filter(Boolean).length === H75_TASKS.length;
    const future = dk > TODAY; const isToday = dk === TODAY;
    const beforeStart = h75.start && dk < h75.start;
    const dot = document.createElement('div');
    dot.innerHTML = `<span>${d.getDate()}.${d.getMonth()+1}</span>`;
    if (future || beforeStart || !h75.start) dot.className = 'sdot future';
    else if (isToday) dot.className = 'sdot today';
    else if (allDone) dot.className = 'sdot done';
    else dot.className = 'sdot miss';
    dotsEl.appendChild(dot);
  }

  const startLbl = document.getElementById('h75-start-label');
  if (startLbl) startLbl.textContent = h75.start ? `Started · ${new Date(h75.start).toLocaleDateString('de-DE',{day:'numeric',month:'long',year:'numeric'})}` : '';

  const todayChecks = (h75.days||{})[TODAY] || {};
  const cl = document.getElementById('h75-checklist');
  cl.innerHTML = '';
  H75_TASKS.forEach((item, idx) => {
    const done = !!todayChecks[idx];
    const el = document.createElement('div');
    el.className = `ri${done ? ' done' : ''}`;
    el.innerHTML = `<div class="ri-em">${item.em}</div><div class="ri-body"><div class="ri-title">${item.tx}</div><div class="ri-hint">${item.note||''}</div></div><div class="ri-check">${done?'✓':''}</div>`;
    el.onclick = () => {
      if (!S.h75.days) S.h75.days = {};
      if (!S.h75.days[TODAY]) S.h75.days[TODAY] = {};
      S.h75.days[TODAY][idx] = !S.h75.days[TODAY][idx];
      upsert('h75', S.h75); playSound('check'); renderH75();
    };
    cl.appendChild(el);
  });

  const allToday = Object.values(todayChecks).filter(Boolean).length === H75_TASKS.length && dayNum > 0;
  document.getElementById('h75-day-complete').classList.toggle('show', allToday);
  if (allToday) playSound('milestone');
  renderWater();
}

function renderWater() {
  const c = document.getElementById('water-glasses');
  c.innerHTML = '';
  for (let i = 0; i < 8; i++) {
    const b = document.createElement('div');
    b.className = `glass${i < S.water ? ' filled' : ''}`;
    b.onclick = () => {
      S.water = i < S.water ? i : i + 1;
      upsert(`water_${TODAY}`, S.water); renderWater();
    };
    c.appendChild(b);
  }
  document.getElementById('water-label').textContent = `${S.water} / 8 Gläser`;
}

document.getElementById('post-toggle').onchange = function() {
  S.post = this.checked;
  updatePostToggle();
  upsert(`post_${TODAY}`, S.post);
};

function togglePostState() {
  const cb = document.getElementById('post-toggle');
  cb.checked = !cb.checked;
  cb.dispatchEvent(new Event('change'));
}

function updatePostToggle() {
  const vis = document.getElementById('post-toggle-visual');
  const cb = document.getElementById('post-toggle');
  if (vis) vis.classList.toggle('off', !cb.checked);
}

// ══════════════════════════════════════════════════════
// ABEND TAB
// ══════════════════════════════════════════════════════
function renderAbend() {
  const el = document.getElementById('evening-list');
  el.innerHTML = '';
  EVENING_ITEMS.forEach((item, idx) => {
    const done = !!S.evening[idx];
    const div = document.createElement('div');
    div.className = `ri${done ? ' done' : ''}`;
    div.innerHTML = `<div class="ri-em">${item.ic}</div><div class="ri-body"><div class="ri-title">${item.lb}</div><div class="ri-hint">${item.ht}</div></div><div class="ri-check">${done?'✓':''}</div>`;
    div.onclick = () => { S.evening[idx]=!S.evening[idx]; upsert(`evening_${TODAY}`, S.evening); playSound('check'); renderAbend(); };
    el.appendChild(div);
  });
  initSliders();
}

function initSliders() {
  const es = document.getElementById('energy-slider');
  const ms = document.getElementById('mood-slider');
  if (!es||!ms) return;
  es.value = S.mood?.energy || 5;
  ms.value = S.mood?.mood || 5;
  const ev = document.getElementById('energy-val');
  const mv = document.getElementById('mood-val');
  if (ev) ev.textContent = es.value;
  if (mv) mv.textContent = ms.value;
  es.oninput = () => { if (ev) ev.textContent=es.value; S.mood.energy=+es.value; upsert(`mood_${TODAY}`,S.mood); };
  ms.oninput = () => { if (mv) mv.textContent=ms.value; S.mood.mood=+ms.value; upsert(`mood_${TODAY}`,S.mood); };
}

function renderStreaks() {
  const cannabisStart = new Date('2026-04-16');
  const daysFree = Math.floor((new Date()-cannabisStart)/86400000);
  const ccEl = document.getElementById('cannabis-counter');
  if (ccEl) ccEl.textContent = Math.max(0, daysFree);
  const milestones = [[90,'🏆 90 Tage!'],[60,'🌟 2 Monate!'],[30,'💪 1 Monat!'],[21,'🧠 21 Tage!'],[14,'⚡ 2 Wochen!'],[7,'✅ 1 Woche!']];
  const ms = milestones.find(([d])=>daysFree>=d);
  const msEl = document.getElementById('cannabis-milestone');
  if (msEl && ms) msEl.textContent = ms[1];
  dbRead('gym_streak').then(v => {
    const el = document.getElementById('gym-streak-counter');
    if (el) el.textContent = v||'–';
  });
}

// ══════════════════════════════════════════════════════
// TRACKING (Cannabis / Microdosing)
// ══════════════════════════════════════════════════════
function toggleTracking(type) {
  if (!S.tracking) S.tracking = {};
  S.tracking[type] = !S.tracking[type];
  applyTrackingStyle(type);
  if (type==='microdose') {
    const wrap = document.getElementById('microdose-notes-wrap');
    if (wrap) wrap.style.display = S.tracking.microdose ? 'block' : 'none';
  }
  upsert(`tracking_${TODAY}`, S.tracking);
  playSound('check');
}

function applyTrackingStyle(type) {
  const btn = document.getElementById(type==='cannabis'?'cannabis-btn':'microdose-btn');
  if (!btn) return;
  const active = S.tracking?.[type];
  btn.classList.toggle('on', !!active);
}

// ══════════════════════════════════════════════════════
// VOICE
// ══════════════════════════════════════════════════════
let recognition = null;
function toggleVoice() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { alert('Spracheingabe nicht unterstützt'); return; }
  if (recognition) { recognition.stop(); return; }
  recognition = new SR();
  recognition.lang = 'de-DE'; recognition.continuous = true; recognition.interimResults = false;
  recognition.onresult = e => {
    const t = Array.from(e.results).map(r=>r[0].transcript).join(' ');
    const ta = document.getElementById('notes-textarea');
    ta.value = (ta.value ? ta.value+' ' : '') + t;
    ta.dispatchEvent(new Event('input'));
  };
  recognition.onerror = recognition.onend = () => {
    recognition = null;
    document.getElementById('voice-btn').textContent = '🎙️';
    document.getElementById('voice-status').textContent = 'Tippen oder sprechen';
  };
  recognition.start();
  document.getElementById('voice-btn').textContent = '🔴';
  document.getElementById('voice-status').textContent = 'Aufnahme läuft...';
}

let todoRec = null;
function toggleTodoVoice() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) return;
  if (todoRec) { todoRec.stop(); return; }
  todoRec = new SR();
  todoRec.lang = 'de-DE'; todoRec.interimResults = false;
  todoRec.onresult = e => { document.getElementById('todo-input').value = e.results[0][0].transcript; todoRec=null; document.getElementById('todo-voice-btn').textContent='🎙️'; };
  todoRec.onerror = todoRec.onend = () => { todoRec=null; document.getElementById('todo-voice-btn').textContent='🎙️'; };
  todoRec.start();
  document.getElementById('todo-voice-btn').textContent = '🔴';
}

// ══════════════════════════════════════════════════════
// TODOS
// ══════════════════════════════════════════════════════
function addTodo() {
  const inp = document.getElementById('todo-input');
  const text = inp.value.trim(); if (!text) return;
  if (!S.all_todos) S.all_todos = [];
  const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate()+1);
  const dateStr = tomorrow.toISOString().split('T')[0];
  S.all_todos.push({ id: `todo_${Date.now()}`, text, date: dateStr, status: 'pending', source: 'manual' });
  inp.value = '';
  renderTodos(); renderPlan();
  upsert('all_todos', S.all_todos);
}

function toggleTodo(id) {
  const t = (S.all_todos||[]).find(x=>x.id===id);
  if (!t) return;
  t.status = t.status==='done' ? 'pending' : 'done';
  playSound('check');
  renderTodos(); renderPlan();
  upsert('all_todos', S.all_todos);
}

function renderTodos() {
  const today = TODAY;
  const todayTodos = (S.all_todos||[]).filter(t=>t.date===today && t.status==='pending');
  const tomorrowTodos = (S.all_todos||[]).filter(t=>{
    const d=new Date(today); d.setDate(d.getDate()+1);
    return t.date===d.toISOString().split('T')[0] && t.status==='pending';
  });
  ['morgen-todos','todo-list-abend'].forEach(id => {
    const el = document.getElementById(id); if (!el) return;
    const list = id==='morgen-todos' ? todayTodos : tomorrowTodos;
    el.innerHTML = list.length ? '' : '<div style="font-size:13px;color:rgba(241,245,249,0.35);padding:8px 0;">Keine Todos</div>';
    list.forEach(t => {
      const d = document.createElement('div');
      d.style = 'display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);';
      d.innerHTML = `<button onclick="toggleTodo('${t.id}')" style="width:22px;height:22px;border-radius:6px;border:1px solid rgba(255,255,255,0.2);background:none;cursor:pointer;flex-shrink:0;"></button><span style="flex:1;font-size:14px;">${t.text}</span>`;
      el.appendChild(d);
    });
  });
}

// ══════════════════════════════════════════════════════
// PLAN TAB
// ══════════════════════════════════════════════════════
function renderPlan() {
  renderWeekCalendar();
  renderTimeline();
  renderDecisionCountdown();
  const sidebar = document.getElementById('desktop-plan-content');
  const src = document.getElementById('plan-timeline');
  if (sidebar && src) sidebar.innerHTML = src.innerHTML;
}

function renderWeekCalendar() {
  const el = document.getElementById('plan-week-calendar');
  if (!el) return;
  el.innerHTML = '';
  const days = ['Mo','Di','Mi','Do','Fr','Sa','So'];
  const now = new Date();
  const weekStart = new Date(now);
  weekStart.setDate(now.getDate() - ((now.getDay()||7) - 1));
  for (let i=0;i<7;i++) {
    const d = new Date(weekStart); d.setDate(weekStart.getDate()+i);
    const ds = d.toISOString().split('T')[0];
    const isToday = ds === TODAY;
    const hasTodos = (S.all_todos||[]).some(t=>t.date===ds&&t.status==='pending');
    const cell = document.createElement('div');
    cell.className = `day${isToday?' today':''}`;
    cell.innerHTML = `<div class="d-lbl">${days[i]}</div><div class="d-num">${d.getDate()}</div>${hasTodos?`<div class="d-dot${isToday?'':' green'}"><span></span></div>`:''}`;
    el.appendChild(cell);
  }
}

function renderTimeline() {
  const el = document.getElementById('plan-timeline');
  if (!el) return;
  const todos = (S.all_todos||[]).filter(t=>t.status==='pending').sort((a,b)=>a.date.localeCompare(b.date));
  const groups = {};
  const now = new Date(TODAY);
  todos.forEach(t => {
    const diff = Math.floor((new Date(t.date)-now)/86400000);
    const label = diff<0?null:diff===0?'Heute':diff===1?'Morgen':diff<=7?'Diese Woche':'Später';
    if (!label) return;
    if (!groups[label]) groups[label]=[];
    groups[label].push(t);
  });
  const colors = {'Heute':'#ef4444','Morgen':'#f59e0b','Diese Woche':'#6366f1','Später':'#475569'};
  el.innerHTML = '';
  Object.entries(groups).forEach(([label,items])=>{
    const section = document.createElement('div');
    section.style.cssText = 'margin-bottom:16px;';
    section.innerHTML = `<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;"><div style="width:10px;height:10px;border-radius:50%;background:${colors[label]};box-shadow:0 0 8px ${colors[label]};flex-shrink:0;"></div><span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:${colors[label]};">${label}</span></div>`;
    items.forEach(t=>{
      const div=document.createElement('div');
      div.style.cssText=`display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card);border:1px solid var(--card-border);border-left:3px solid ${colors[label]};border-radius:10px;margin-bottom:6px;cursor:pointer;`;
      div.innerHTML=`<span style="flex:1;font-size:13px;">${t.text}</span><span style="font-size:11px;color:var(--text-muted);">${t.date}</span>`;
      div.onclick=()=>{ toggleTodo(t.id); };
      section.appendChild(div);
    });
    el.appendChild(section);
  });
  if (!el.innerHTML) el.innerHTML='<div style="text-align:center;padding:40px 0;color:var(--text-muted);font-size:13px;">Keine offenen To-Dos 🎉</div>';
}

function renderDecisionCountdown() {
  const target = new Date('2026-09-01');
  const days = Math.max(0, Math.floor((target-new Date())/86400000));
  const el = document.getElementById('decision-countdown');
  if (el) el.textContent = days;
}

// ══════════════════════════════════════════════════════
// INCOME TRACKER
// ══════════════════════════════════════════════════════
function getWeekKey() {
  const d=new Date(), y=d.getFullYear();
  const start=new Date(y,0,1);
  const week=Math.ceil(((d-start)/86400000+start.getDay()+1)/7);
  return `${y}-W${week}`;
}

async function saveIncome() {
  const val = +document.getElementById('income-input').value||0;
  if (!val) return;
  const week = getWeekKey();
  const current = await dbRead(`income_${week}`) || 0;
  const total = current + val;
  await upsert(`income_${week}`, total);
  document.getElementById('income-display').textContent = total+' €';
  document.getElementById('income-input').value='';
  playSound('milestone');
}

async function loadIncome() {
  const total = await dbRead(`income_${getWeekKey()}`)||0;
  const el = document.getElementById('income-display');
  if (el) el.textContent = total+' €';
}

// ══════════════════════════════════════════════════════
// NOTES
// ══════════════════════════════════════════════════════
const notesEl = document.getElementById('notes-textarea');
notesEl.oninput = () => {
  clearTimeout(notesTimer);
  notesTimer = setTimeout(async () => {
    S.notes = notesEl.value;
    await upsert(`journal_${TODAY}`, S.notes);
    const t = new Date().toLocaleTimeString('de-DE',{hour:'2-digit',minute:'2-digit'});
    document.getElementById('notes-ts').textContent = `Gespeichert ${t}`;
  }, 1000);
};

document.getElementById('microdose-notes').oninput = () => {
  if (!S.tracking) S.tracking = {};
  S.tracking.microdose_note = document.getElementById('microdose-notes').value;
  upsert(`tracking_${TODAY}`, S.tracking);
};

// ══════════════════════════════════════════════════════
// SETTINGS
// ══════════════════════════════════════════════════════
function loadSettings() {
  const c = getCfg();
  document.getElementById('sb-url').value = c.url;
  document.getElementById('sb-key').value = c.key;
  document.getElementById('last-wo-sel').value = S.wo_last;
  if (S.h75.start) document.getElementById('h75-start-in').value = S.h75.start;
  updateSplitPicker(S.wo_last);
}

function updateSplitPicker(val) {
  document.querySelectorAll('#last-wo-picker .sp').forEach(btn => {
    btn.classList.toggle('on', btn.textContent.trim() === (val||'').toUpperCase());
  });
}

document.getElementById('sb-url').oninput = function() { localStorage.setItem('sb_url', this.value.trim()); };
document.getElementById('sb-key').oninput = function() { localStorage.setItem('sb_key', this.value.trim()); };

async function testConn() {
  const c = getCfg(); const s = document.getElementById('conn-status');
  if (!c.url||!c.key) { s.innerHTML='<span class="s-err">✗ Keine Credentials</span>'; return; }
  s.textContent='Teste...';
  try {
    const r = await fetch(`${c.url}/rest/v1/app_state?limit=1`,{headers:{'apikey':c.key,'Authorization':`Bearer ${c.key}`}});
    s.innerHTML = r.ok ? '<span class="s-ok">✓ Verbindung OK</span>' : `<span class="s-err">✗ Fehler ${r.status}</span>`;
  } catch(e) { s.innerHTML='<span class="s-err">✗ Kein Netzwerk</span>'; }
}

function setLastWo(val) {
  S.wo_last = val;
  const rot=['Pull','Push','Legs'];
  S.wo_current = rot[(rot.indexOf(val)+1)%3];
  upsert('wo_last', val); upsert('wo_current', S.wo_current);
  updateSplitPicker(val);
  renderWorkout();
}

function setH75Start(val) {
  S.h75.start = val || null;
  upsert('h75', S.h75); renderH75();
}

function copySQL() {
  navigator.clipboard.writeText(document.getElementById('sql-snippet').textContent).catch(()=>{});
}

function exportData() {
  const data={};
  for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);try{data[k]=JSON.parse(localStorage.getItem(k));}catch{data[k]=localStorage.getItem(k);}}
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));
  a.download=`samuel-export-${TODAY}.json`; a.click();
}

function resetAll() {
  if (!confirm('Bist du sicher? Alle Daten werden gelöscht.')) return;
  if (!confirm('Wirklich alles löschen? Kann nicht rückgängig gemacht werden.')) return;
  const su=localStorage.getItem('sb_url'), sk=localStorage.getItem('sb_key');
  localStorage.clear();
  if(su) localStorage.setItem('sb_url',su);
  if(sk) localStorage.setItem('sb_key',sk);
  location.reload();
}

// ══════════════════════════════════════════════════════
// BEDTIME RING
// ══════════════════════════════════════════════════════
function renderBedtimeRing() {
  const now = new Date();
  const wakeHour = 6;
  const sleepHour = 23;
  const totalDayMinutes = (sleepHour - wakeHour) * 60;
  const elapsedMinutes = Math.max(0, (now.getHours() - wakeHour) * 60 + now.getMinutes());
  const pct = Math.min(1, elapsedMinutes / totalDayMinutes);

  const CIRC = 351.86;
  const offset = CIRC - pct * CIRC;
  const ring = document.getElementById('bedtime-ring-track');
  const pctEl = document.getElementById('bedtime-pct');
  const labelEl = document.getElementById('bedtime-label');
  if (!ring) return;

  ring.style.strokeDashoffset = offset.toFixed(2);
  const color = pct < 0.7 ? 'rgba(190,195,215,0.85)' : pct < 0.9 ? 'var(--amber)' : 'var(--red, #ef4444)';
  ring.style.stroke = color;

  if (pctEl) pctEl.textContent = Math.round(pct * 100) + '%';

  const sleepTime = new Date(now);
  sleepTime.setHours(sleepHour, 0, 0, 0);
  const diffMs = sleepTime - now;
  if (labelEl) {
    if (diffMs > 0) {
      const hLeft = Math.floor(diffMs / 3600000);
      const mLeft = Math.floor((diffMs % 3600000) / 60000);
      labelEl.textContent = `${hLeft}h ${mLeft}m bis Schlafenszeit · Ziel: 23:00`;
    } else {
      labelEl.textContent = '🌙 Zeit zum Schlafen';
      ring.style.stroke = 'var(--accent)';
    }
  }
}

// ══════════════════════════════════════════════════════
// SUPPLEMENT TRACKER
// ══════════════════════════════════════════════════════
const SUPPS = [
  { id:'kreatin',     label:'Kreatin',           emoji:'💪', max:1, note:null },
  { id:'ltheanin',    label:'L-Theanin',          emoji:'🧠', max:1, note:'⚠️ Letzte Tablette — nachbestellen!' },
  { id:'magnesium',   label:'Magnesium',           emoji:'⚡', max:1, note:null },
  { id:'ashwagandha', label:'Ashwagandha 1.500mg', emoji:'🌿', max:1, note:null },
  { id:'omega3',      label:'Omega-3 Algenöl',    emoji:'🐟', max:1, note:'⚠️ Nicht vorrätig — nachbestellen!' },
  { id:'vitamind',    label:'Vitamin D3 + K2',    emoji:'☀️', max:1, note:null },
  { id:'vitaminc',    label:'Vitamin C 1.000mg',  emoji:'🍋', max:2, note:'2× 500mg' },
  { id:'probiona',    label:'Probiona',            emoji:'🦠', max:1, note:'20 Mrd KBE' },
  { id:'purella',     label:'Purella',             emoji:'🌱', max:1, note:'Optional' },
];

function getSuppState() {
  const raw = localStorage.getItem('supp_state');
  const today = new Date().toDateString();
  if (!raw) return { date: today, logs: {}, outOfStock: {} };
  const s = JSON.parse(raw);
  if (!s.outOfStock) s.outOfStock = {};
  const now = new Date();
  if (s.date !== today && now.getHours() >= 6) return { date: today, logs: {}, outOfStock: s.outOfStock };
  return s;
}
function saveSuppState(state) {
  localStorage.setItem('supp_state', JSON.stringify(state));
}
function logSupp(id) {
  const state = getSuppState();
  const supp = SUPPS.find(s => s.id === id);
  if (!state.logs[id]) state.logs[id] = [];
  if (state.logs[id].length >= supp.max) return;
  if (state.outOfStock[id]) return;
  state.logs[id].push(new Date().toTimeString().slice(0,5));
  saveSuppState(state);
  renderSupps();
}
function toggleOutOfStock(id) {
  const state = getSuppState();
  state.outOfStock[id] = !state.outOfStock[id];
  saveSuppState(state);
  renderSupps();
}
function renderSupps() {
  const state = getSuppState();
  const el = document.getElementById('supp-list');
  if (!el) return;

  el.innerHTML = SUPPS.map(supp => {
    const logs = state.logs[supp.id] || [];
    const taken = logs.length;
    const done = taken >= supp.max;
    const oos = !!state.outOfStock[supp.id];
    const blocked = done || oos;

    let statusText = '';
    if (oos) statusText = '❌ Nicht vorrätig';
    else if (done) statusText = logs.map(t => `✓ ${t}`).join(' · ');
    else if (taken > 0) statusText = logs.map(t => `✓ ${t}`).join(' · ') + ` · ${supp.max - taken}x übrig`;
    else statusText = supp.note || `0 / ${supp.max} heute`;

    const bg = oos ? 'transparent' : done ? 'var(--green-soft)' : 'var(--card)';
    const border = oos ? 'rgba(190,195,215,0.08)' : done ? 'var(--green-border)' : 'var(--card-border)';
    const labelColor = oos ? 'var(--text-muted)' : done ? 'var(--green)' : 'var(--text)';

    return `<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:6px;background:${bg};border:1px solid ${border};border-radius:12px;opacity:${oos?'0.6':'1'};">
      <span style="font-size:20px;">${supp.emoji}</span>
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:600;color:${labelColor};">${supp.label}</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${statusText}</div>
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0;">
        <button onclick="toggleOutOfStock('${supp.id}')" title="${oos?'Wieder vorrätig':'Nicht vorrätig markieren'}"
          style="padding:6px 8px;border-radius:8px;border:1px solid rgba(190,195,215,0.15);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;">
          ${oos ? '↩' : '✕'}
        </button>
        <button onclick="logSupp('${supp.id}')"
          ${blocked?'disabled':''}
          style="padding:7px 14px;border-radius:9px;border:1px solid ${done?'var(--green-border)':blocked?'rgba(190,195,215,0.1)':'var(--card-border-hover, var(--card-border))'};background:${done?'var(--green-soft)':blocked?'transparent':'var(--accent-soft, rgba(190,195,215,0.07))'};color:${done?'var(--green)':blocked?'var(--text-muted)':'var(--accent-solid, var(--accent))'};font-size:12px;font-weight:600;cursor:${blocked?'default':'pointer'};">
          ${done ? '✓' : oos ? '—' : 'Nehmen'}
        </button>
      </div>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════════════════
// WORKOUT HISTORY
// ══════════════════════════════════════════════════════
function saveWorkoutToHistory(session, split) {
  const MAX = 7;
  let hist = [];
  try { hist = JSON.parse(localStorage.getItem('wo_history')) || []; } catch { hist = []; }
  const exercises = (session.exercises || []).map(ex => {
    const logged = (ex.sets || []).filter(s => s != null);
    const maxKg = logged.reduce((acc, s) => s.bw ? acc : Math.max(acc, s.kg || 0), 0);
    const totalReps = logged.reduce((acc, s) => acc + (parseInt(s.reps) || 0), 0);
    return { name: ex.name, sets: logged.length, maxKg, totalReps };
  }).filter(e => e.sets > 0);
  hist.unshift({ date: TODAY, split, exercises });
  if (hist.length > MAX) hist = hist.slice(0, MAX);
  localStorage.setItem('wo_history', JSON.stringify(hist));
}

function renderWorkoutHistory() {
  const wrap = document.getElementById('wo-history-wrap');
  if (!wrap) return;
  let hist = [];
  try { hist = JSON.parse(localStorage.getItem('wo_history')) || []; } catch { hist = []; }
  if (!hist.length) { wrap.innerHTML = '<div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Noch keine Sessions gespeichert.</div>'; return; }

  const splitColor = { Pull: 'var(--accent)', Push: 'var(--green)', Legs: 'var(--amber)' };

  wrap.innerHTML = hist.map(entry => {
    const allKgs = entry.exercises.map(e => e.maxKg).filter(k => k > 0);
    const maxKg = allKgs.length ? Math.max(...allKgs) : 1;
    const bars = entry.exercises.map(ex => {
      const pct = maxKg > 0 ? Math.round((ex.maxKg / maxKg) * 100) : 0;
      const color = splitColor[entry.split] || 'var(--accent)';
      const val = ex.maxKg > 0 ? `${ex.maxKg}kg` : `${ex.totalReps}×`;
      return `<div class="wo-hist-row">
        <div class="wo-hist-exname">${ex.name}</div>
        <div class="wo-hist-bar-wrap"><div class="wo-hist-bar" style="width:${pct}%;background:${color};"></div></div>
        <div class="wo-hist-val">${val}</div>
      </div>`;
    }).join('');

    const [y, m, d] = entry.date.split('-');
    const dateStr = `${d}.${m}.${y}`;
    return `<div class="wo-hist-entry">
      <div class="wo-hist-head">
        <div class="wo-hist-split">${entry.split.toUpperCase()}</div>
        <div class="wo-hist-date">${dateStr}</div>
      </div>
      <div class="wo-hist-bars">${bars}</div>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
async function init() {
  flushPendingSync(); // re-sync failed writes from previous sessions (fire-and-forget)
  const lastDay = localStorage.getItem('_last_day');
  if (lastDay && lastDay !== TODAY) {
    Object.keys(TS).forEach(k => {
      const item = ROUTINE[+k];
      if (item?.type==='timer') TS[k] = {active:false, remaining:item.duration*60, open:false, interval:null};
    });
  }
  localStorage.setItem('_last_day', TODAY);

  soundEnabled = localStorage.getItem('soundEnabled') !== 'false';
  document.getElementById('sound-toggle').textContent = soundEnabled ? 'An' : 'Aus';

  renderGreeting();
  renderDate();
  renderQuote();
  loadWeather();

  const [routine,woLast,woCurr,woSess,h75,water,post,mood,notes,evening,tracking,allTodos,woPlan,woRecords] = await Promise.all([
    dbRead(`r_${TODAY}`),
    dbRead('wo_last'),
    dbRead('wo_current'),
    dbRead(`wo_session_${TODAY}`),
    dbRead('h75'),
    dbRead(`water_${TODAY}`),
    dbRead(`post_${TODAY}`),
    dbRead(`mood_${TODAY}`),
    dbRead(`journal_${TODAY}`),
    dbRead(`evening_${TODAY}`),
    dbRead(`tracking_${TODAY}`),
    dbRead('all_todos'),
    dbRead('wo_plan'),
    dbRead('wo_records'),
  ]);

  S.routine = routine || {};
  S.wo_last = woLast || 'Pull';
  S.wo_current = woCurr || 'Push';
  S.wo_session = woSess || {};
  S.h75 = h75 || {start:null, days:{}};
  S.water = water || 0;
  S.post = post || false;
  S.mood = mood || {energy:5, mood:5};
  S.notes = notes || '';
  S.evening = evening || {};
  S.tracking = tracking || {};
  S.all_todos = allTodos || [];

  // Load workout plan from Supabase; write DEFAULT_PLAN on first run
  WP = woPlan || null;
  S.wo_records = woRecords || {};
  if (!woPlan) { upsert('wo_plan', DEFAULT_PLAN); } // first-run: seed Supabase

  renderRoutineList();
  renderWorkout();
  renderH75();
  renderWater();
  document.getElementById('post-toggle').checked = S.post;
  updatePostToggle();
  renderAbend();
  notesEl.value = S.notes;
  loadSettings();

  applyTrackingStyle('cannabis');
  applyTrackingStyle('microdose');
  if (S.tracking?.microdose) {
    const wrap = document.getElementById('microdose-notes-wrap');
    if (wrap) wrap.style.display = 'block';
  }
  if (S.tracking?.microdose_note) {
    const noteEl = document.getElementById('microdose-notes');
    if (noteEl) noteEl.value = S.tracking.microdose_note;
  }

  renderTodos();
  renderPlan();
  renderStreaks();
  renderDecisionCountdown();
  loadIncome();
  initSliders();
  renderHeatmap();

  renderBedtimeRing();
  setInterval(renderBedtimeRing, 60000);

  renderSupps();
  loadGesundheitTab();

  renderWorkoutHistory();

  setTimeout(() => playSound('welcome'), 500);

  if ('serviceWorker' in navigator) navigator.serviceWorker.register('sw.js').catch(()=>{});
}

init();

// ═══ JARVIS Stufe 1 ═══
let jarvisVoiceOn = false;
let jarvisHistory = [];

function jarvisToggle(){ document.getElementById('jarvis-panel').classList.toggle('open'); }

function jarvisSystemPrompt(){
  return `Du bist Jarvis, Samuels persönlicher Assistent in seiner Dashboard-App. Antworte auf Deutsch, kurz und direkt, kein Geschwafel.
Ton: Motivational Bro — ehrlich, reflektiert, anfeuernd, kein Kitsch. Du willst, dass Samuel alles schafft.
Über Samuel: 21, aus Neuburg, ADHS. Kreuzbandriss im Januar -> trainiert NUR Oberkörper (Pull/Push). Baut Morgenroutine + Gym auf, lebt 75Hard-artig. Will unabhängiger werden.
Du kennst seine Live-Daten (unten). Beziehe dich konkret darauf. Wenn er etwas erledigen/merken will, nutze das Tool add_todo. Erfinde keine Daten.`;
}

function gatherJarvisContext(){
  const today = TODAY;
  const todos = (S.all_todos||[]).filter(t=>t.status==='pending').map(t=>`- ${t.text} (${t.date})`).join('\n') || 'keine offenen';
  const streak = localStorage.getItem('gym_streak') || '?';
  const woCur = localStorage.getItem('wo_current') || '?';
  return `Datum heute: ${today}\nGym-Streak: ${streak}\nNächstes/aktuelles Workout: ${woCur}\nOffene To-Dos:\n${todos}`;
}

const JARVIS_TOOLS = [{
  type:"function",
  function:{
    name:"add_todo",
    description:"Fügt ein To-Do zu Samuels Liste hinzu, wenn er etwas erledigen oder sich merken will.",
    parameters:{ type:"object", properties:{
      text:{type:"string", description:"Die Aufgabe"},
      date:{type:"string", description:"Datum YYYY-MM-DD, Standard heute"}
    }, required:["text"] }
  }
}];

function jarvisAddTodo(text, date){
  if(!S.all_todos) S.all_todos = [];
  S.all_todos.push({ id:`todo_${Date.now()}`, text, date: date||TODAY, status:'pending', source:'jarvis' });
  upsert('all_todos', S.all_todos);
  if(typeof renderTodos === 'function') renderTodos();
  return `To-Do gespeichert: ${text} (${date||TODAY})`;
}

function jarvisPushMsg(who, text){
  const box = document.getElementById('jarvis-msgs');
  const d = document.createElement('div');
  d.className = 'jmsg ' + (who==='user'?'user':'jarvis');
  d.textContent = text;
  box.appendChild(d); box.scrollTop = box.scrollHeight;
}

async function jarvisCall(payload){
  const c = getCfg();
  const res = await fetch(`${c.url}/functions/v1/jarvis`, {
    method:'POST',
    headers:{ apikey:c.key, Authorization:`Bearer ${c.key}`, 'Content-Type':'application/json' },
    body: JSON.stringify(payload)
  });
  return res;
}

async function jarvisAsk(userText){
  const c = getCfg();
  if(!c.url || !c.key) return 'Supabase ist nicht verbunden (Settings-Tab).';
  const sys = { role:'system', content: jarvisSystemPrompt() + '\n\nAktuelle Daten:\n' + gatherJarvisContext() };
  jarvisHistory.push({ role:'user', content:userText });
  try{
    let res = await jarvisCall({ type:'chat', messages:[sys, ...jarvisHistory.slice(-10)], tools:JARVIS_TOOLS });
    let data = await res.json();
    let msg = data.choices?.[0]?.message;
    if(!msg) return 'Hm, da kam keine Antwort. (' + (data.error||'unbekannt') + ')';

    if(msg.tool_calls?.length){
      jarvisHistory.push(msg);
      for(const tc of msg.tool_calls){
        let result = 'ok';
        if(tc.function.name === 'add_todo'){
          const a = JSON.parse(tc.function.arguments || '{}');
          result = jarvisAddTodo(a.text, a.date);
        }
        jarvisHistory.push({ role:'tool', tool_call_id:tc.id, content:result });
      }
      res = await jarvisCall({ type:'chat', messages:[sys, ...jarvisHistory.slice(-12)] });
      data = await res.json();
      const reply = data.choices?.[0]?.message?.content || 'Erledigt.';
      jarvisHistory.push({ role:'assistant', content:reply });
      return reply;
    }
    jarvisHistory.push({ role:'assistant', content:msg.content });
    return msg.content;
  } catch(e){ return 'Fehler: ' + e; }
}

async function jarvisSend(){
  const inp = document.getElementById('jarvis-text');
  const t = inp.value.trim(); if(!t) return;
  inp.value=''; jarvisPushMsg('user', t);
  const reply = await jarvisAsk(t);
  jarvisPushMsg('jarvis', reply); jarvisSpeak(reply);
}

// ── Push-to-Talk Mikrofon ──
let jarvisRec = null;
let jarvisRecording = false;

function setJarvisMicUI(on){
  const b = document.getElementById('jarvis-mic-btn');
  const inp = document.getElementById('jarvis-text');
  if(b){ b.classList.toggle('recording', on); b.textContent = on ? '⏹️' : '🎙️'; }
  if(inp){ inp.classList.toggle('listening', on); inp.placeholder = on ? 'Höre zu… nochmal drücken zum Senden' : 'Schreib oder sprich…'; }
}

function jarvisMicToggle(){
  if(jarvisRecording){ jarvisStopMic(); return; }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SR){ jarvisPushMsg('jarvis','Spracherkennung wird hier nicht unterstützt — tippe bitte (z.B. mit Wispr Flow direkt ins Textfeld).'); return; }
  jarvisRec = new SR();
  jarvisRec.lang = 'de-DE';
  jarvisRec.continuous = true;
  jarvisRec.interimResults = true;

  jarvisRec.onresult = (e)=>{
    let finalText = '';
    for(let i=0;i<e.results.length;i++){
      finalText += e.results[i][0].transcript + (e.results[i].isFinal ? ' ' : '');
    }
    const inp = document.getElementById('jarvis-text');
    if(inp) inp.value = finalText.trim();
  };
  jarvisRec.onend = ()=>{ if(jarvisRecording){ try{ jarvisRec.start(); }catch(_){} } };
  jarvisRec.onerror = (e)=>{ if(e.error !== 'no-speech' && e.error !== 'aborted') jarvisPushMsg('jarvis','Mikro-Fehler: '+e.error); };

  jarvisRecording = true;
  setJarvisMicUI(true);
  try{ jarvisRec.start(); }catch(_){}
}

function jarvisStopMic(){
  jarvisRecording = false;
  setJarvisMicUI(false);
  if(jarvisRec){ try{ jarvisRec.stop(); }catch(_){} }
  const inp = document.getElementById('jarvis-text');
  const text = (inp ? inp.value : '').trim();
  if(inp) inp.value = '';
  if(text){
    jarvisPushMsg('user', text);
    jarvisAsk(text).then(reply=>{ jarvisPushMsg('jarvis', reply); jarvisSpeak(reply); });
  }
}

async function jarvisSpeak(text){
  if(!jarvisVoiceOn) return;
  try{
    const res = await jarvisCall({ type:'tts', text });
    if(!res.ok) return;
    const buf = await res.arrayBuffer();
    const url = URL.createObjectURL(new Blob([buf], { type:'audio/mpeg' }));
    new Audio(url).play();
  } catch(e){}
}

async function jarvisCheckin(){
  const h = new Date().getHours();
  const phase = h < 11 ? 'Morgen' : h < 17 ? 'Mittag' : 'Abend';
  jarvisPushMsg('jarvis', '…');
  const reply = await jarvisAsk(`(System: Starte den ${phase}-Check-in. Begrüße mich kurz und persönlich anhand meiner Daten und stelle die passenden Fragen für die Tageszeit „${phase}".)`);
  document.querySelector('#jarvis-msgs .jmsg.jarvis:last-child').textContent = reply;
  jarvisSpeak(reply);
}

</script>

<!-- ═══ JARVIS Stufe 1 (provisorisches Panel) ═══ -->
<button id="jarvis-fab" onclick="jarvisToggle()" aria-label="Jarvis">🔵</button>
<div id="jarvis-panel">
  <div id="jarvis-head">
    <span>Jarvis</span>
    <label style="font-size:11px;display:flex;align-items:center;gap:5px;cursor:pointer;">
      <input type="checkbox" id="jarvis-voice" onchange="jarvisVoiceOn=this.checked"> Vorlesen
    </label>
    <button onclick="jarvisCheckin()" class="jarvis-mini">Check-in</button>
    <button onclick="jarvisToggle()" class="jarvis-mini">✕</button>
  </div>
  <div id="jarvis-msgs"></div>
  <div id="jarvis-input">
    <input id="jarvis-text" placeholder="Schreib oder sprich…" onkeydown="if(event.key==='Enter')jarvisSend()">
    <button id="jarvis-mic-btn" onclick="jarvisMicToggle()" class="jarvis-mini" title="Aufnahme starten/stoppen">🎙️</button>
    <button onclick="jarvisSend()" class="jarvis-mini">➤</button>
  </div>
</div>

</body>
</html>
