      <div class="modal-val-display" id="ex-edit-kg" style="min-width:80px;">—</div>
      <button class="modal-adj-btn" onclick="editTargetKg(2.5)">＋</button>
    </div>
    <p class="modal-set-lbl" style="margin-top:12px;margin-bottom:6px;">Was hast du geändert? (optional)</p>
    <textarea id="ex-edit-note" class="ex-note-input" placeholder="z.B. 'Schulter zieht → weniger Gewicht' — wird beim Guten Morgen besprochen"></textarea>
    <button class="modal-action-btn primary" onclick="saveExEdit()">✓ Für heute übernehmen</button>
  </div>

  <!-- ════════════════ EXTRA EXERCISE MODAL ════════════════ -->
  <div id="extra-ex-overlay" onclick="closeExtraEx()"></div>
  <div id="extra-ex-modal">
    <div class="modal-handle"></div>
    <div class="modal-title">Übung hinzufügen</div>
    <input id="extra-ex-name-input" type="text" placeholder="Übungsname…" autocomplete="off">
