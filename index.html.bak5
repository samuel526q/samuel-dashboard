        <button onclick="logKneePain(0)" class="knee-btn" data-val="0" style="flex:1;padding:6px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);color:var(--amber);font-size:12px;cursor:pointer;">0 – kein</button>
        <button onclick="logKneePain(1)" class="knee-btn" data-val="1" style="flex:1;padding:6px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);color:var(--amber);font-size:12px;cursor:pointer;">1 – leicht</button>
        <button onclick="logKneePain(2)" class="knee-btn" data-val="2" style="flex:1;padding:6px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);color:var(--amber);font-size:12px;cursor:pointer;">2 – mäßig</button>
        <button onclick="logKneePain(3)" class="knee-btn" data-val="3" style="flex:1;padding:6px;border-radius:8px;border:1px solid rgba(245,158,11,0.3);background:rgba(245,158,11,0.05);color:var(--amber);font-size:12px;cursor:pointer;">3 – stark</button>
